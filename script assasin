local function GetRoot()
    local c = LocalPlayer.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function GetHP(player)
    local c = player.Character; if not c then return 0,100 end
    local h = c:FindFirstChildOfClass("Humanoid"); if not h then return 0,100 end
    return h.Health, h.MaxHealth
end

local function IsAlive(player)
    local hp,_ = GetHP(player); return hp > 0
end

local function EspCol(player)
    local hp,mx = GetHP(player)
    if mx>0 and hp/mx<0.35 then return Color3.fromRGB(255,150,0) end
    return Config.EspColor
end

