local function CreateESP(player)
    local obj = {boxes={}, conns={}}
    local bb = Instance.new("BillboardGui")
    bb.Size=UDim2.new(0,130,0,60); bb.StudsOffset=Vector3.new(0,4,0)
    bb.AlwaysOnTop=true; bb.ResetOnSpawn=false; bb.MaxDistance=Config.MaxDist
    local nl = Instance.new("TextLabel",bb)
    nl.Size=UDim2.new(1,0,0.45,0); nl.BackgroundTransparency=1
    nl.TextColor3=Config.EspColor; nl.TextStrokeTransparency=0.3
    nl.TextStrokeColor3=Color3.new(0,0,0); nl.Font=Enum.Font.GothamBold
    nl.TextSize=13; nl.Text=player.Name
    local il = Instance.new("TextLabel",bb)
    il.Size=UDim2.new(1,0,0.4,0); il.Position=UDim2.new(0,0,0.5,0)
    il.BackgroundTransparency=1; il.TextColor3=Config.EspColor
    il.TextStrokeTransparency=0.3; il.TextStrokeColor3=Color3.new(0,0,0)
    il.Font=Enum.Font.Gotham; il.TextSize=11; il.Text=""
    obj.bb=bb; obj.nl=nl; obj.il=il
    local function Attach()
        for _,b in ipairs(obj.boxes) do pcall(function() b:Destroy() end) end
        obj.boxes={}
        local char=player.Character; if not char then return end
        for _,pn in ipairs(Config.BodyParts) do
            local part=char:FindFirstChild(pn)
            if part and part:IsA("BasePart") then
                local box=Instance.new("SelectionBox")
                box.Adornee=part; box.Color3=EspCol(player)
                box.LineThickness=0.03; box.SurfaceTransparency=0.82
                box.SurfaceColor3=EspCol(player); box.Parent=workspace
                table.insert(obj.boxes,box)
            end
        end
        local head=char:FindFirstChild("Head")
        if head then bb.Adornee=head; bb.Parent=char end
    end
    Attach()
    table.insert(obj.conns, TC(player.CharacterAdded:Connect(function() task.wait(0.2); Attach() end)))
    table.insert(obj.conns, TC(RunService.Heartbeat:Connect(function()
        if Destroyed or not Config.EspEnabled then return end
        local char=player.Character; if not char then return end
        local head=char:FindFirstChild("Head")
        local root=char:FindFirstChild("HumanoidRootPart")
        local mr=GetRoot()
        if not head or not root or not mr then return end
        local dist=math.floor((root.Position-mr.Position).Magnitude)
        if dist>Config.MaxDist then bb.Parent=nil; for _,b in ipairs(obj.boxes) do b.Visible=false end; return end
        if bb.Parent~=char then bb.Adornee=head; bb.Parent=char end
        local col=EspCol(player)
        nl.TextColor3=col; nl.Visible=Config.ShowName
        local hp,mx=GetHP(player)
        local pts={}
        if Config.ShowHealth and mx>0 then table.insert(pts,string.format("♥%d%%",math.floor(hp/mx*100))) end
        if Config.ShowDist then table.insert(pts,dist.."m") end
        il.Text=table.concat(pts,"  "); il.TextColor3=col
        il.Visible=Config.ShowHealth or Config.ShowDist
        for _,box in ipairs(obj.boxes) do
            if box and box.Parent then box.Color3=col; box.SurfaceColor3=col; box.Visible=Config.ShowBoxes end
        end
    end)))
    return obj
end

local function RemoveESP(player)
    local obj=EspObjects[player]; if not obj then return end
    if obj.bb then pcall(function() obj.bb:Destroy() end) end
    for _,b in ipairs(obj.boxes or {}) do pcall(function() b:Destroy() end) end
    for _,c in ipairs(obj.conns or {}) do pcall(function() c:Disconnect() end) end
    EspObjects[player]=nil
end

local function ClearESP()
    for p,_ in pairs(EspObjects) do RemoveESP(p) end
    EspObjects={}
end

local function RefreshEspColors()
    for _,obj in pairs(EspObjects) do
        if obj.nl then obj.nl.TextColor3=Config.EspColor end
        if obj.il then obj.il.TextColor3=Config.EspColor end
        for _,box in ipairs(obj.boxes or {}) do
            if box and box.Parent then box.Color3=Config.EspColor; box.SurfaceColor3=Config.EspColor end
        end
    end
end

local function EnableESP()
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer then EspObjects[p]=CreateESP(p) end
    end
    TC(Players.PlayerAdded:Connect(function(p) if Config.EspEnabled and not Destroyed then EspObjects[p]=CreateESP(p) end end))
    TC(Players.PlayerRemoving:Connect(function(p) RemoveESP(p) end))
end

