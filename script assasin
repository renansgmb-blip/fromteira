    local tool=bp:FindFirstChildOfClass("Tool"); if not tool then return end
    local char=LocalPlayer.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid"); if not hum then return end
    hum:EquipTool(tool); task.wait(0.4)
end

local function StartAutoKill()
    if autoKillLoop then return end
    Config.HitboxEnabled=true; _G.Disabled=true; _G.HeadSize=Config.HitboxSize
    EquipSlot1()
    local startPos=GetRoot() and GetRoot().Position or Vector3.new(0,0,0)
    autoKillLoop=task.spawn(function()
        while Config.AutoKillEnabled and not Destroyed do
            local root=GetRoot()
            if not root then task.wait(0.3); continue end
            if (root.Position-startPos).Magnitude>Config.MaxTravelDist then
                Config.AutoKillEnabled=false; Config.HitboxEnabled=false
                print("⚠️ Auto Matar parado: saiu +20 studs!")
                if UpdateGUI then UpdateGUI() end
                break
            end
            local enemies={}
            for _,p in ipairs(Players:GetPlayers()) do
                if p==LocalPlayer then continue end
                if not IsAlive(p) then continue end
                local c=p.Character; if not c then continue end
                local rp=c:FindFirstChild("HumanoidRootPart"); if not rp then continue end
                table.insert(enemies,{player=p,rp=rp})
            end
            if #enemies==0 then task.wait(0.5); continue end
            table.sort(enemies,function(a,b)
                return (a.rp.Position-root.Position).Magnitude<(b.rp.Position-root.Position).Magnitude
            end)
            local target=enemies[1]; local trp=target.rp
            if not trp or not trp.Parent then task.wait(0.2); continue end
            local dir=Vector3.new(trp.Position.X-root.Position.X,0,trp.Position.Z-root.Position.Z)
            if dir.Magnitude<0.1 then dir=Vector3.new(1,0,0) end
            dir=dir.Unit
            root.CFrame=CFrame.new(trp.Position+dir*8+Vector3.new(0,Config.HoverHeight,0))
            local timer=tick()
            while tick()-timer<Config.StayOnTargetSec do
                if not Config.AutoKillEnabled or Destroyed then break end
                if not IsAlive(target.player) then break end
                if trp and trp.Parent then
                    local d2=Vector3.new(trp.Position.X-root.Position.X,0,trp.Position.Z-root.Position.Z)
                    if d2.Magnitude<0.1 then d2=Vector3.new(1,0,0) end
                    d2=d2.Unit
                    root.CFrame=CFrame.new(trp.Position+d2*8+Vector3.new(0,Config.HoverHeight,0))
                end
                for _=1,Config.AttackCount do
                    if not Config.AutoKillEnabled or Destroyed then break end
                    SimClick(); task.wait(Config.AttackDelay)
                end
                task.wait(0.05)
            end
            task.wait(0.1)
        end
        Config.HitboxEnabled=false; StopHitbox(); autoKillLoop=nil
        if UpdateGUI then UpdateGUI() end
    end)
end

local function StopAutoKill()
    Config.AutoKillEnabled=false; autoKillLoop=nil
    Config.HitboxEnabled=false; StopHitbox()
end

local function OptimizeGame(enable)
    if enable then
        originalSettings.shadows=Lighting.GlobalShadows
        pcall(function() originalSettings.quality=settings().Rendering.QualityLevel end)
        Lighting.GlobalShadows=false
        pcall(function() settings().Rendering.QualityLevel=Enum.QualityLevel.Level01 end)
        workspace.StreamingMinRadius=64
        for _,v in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire")
                or v:IsA("Smoke") or v:IsA("Sparkles") then v.Enabled=false end
            end)
        end
    else
        if originalSettings.shadows~=nil then Lighting.GlobalShadows=originalSettings.shadows end
        pcall(function() settings().Rendering.QualityLevel=originalSettings.quality or Enum.QualityLevel.Automatic end)
        for _,v in ipairs(workspace:GetDescendants()) do
            pcall(function()
                if v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Fire")
                or v:IsA("Smoke") or v:IsA("Sparkles") then v.Enabled=true end
            end)
        end
    end
end

local function Cleanup()
    Destroyed=true
    Config.EspEnabled=false; Config.AutoKillEnabled=false; Config.HitboxEnabled=false
    autoKillLoop=nil; ClearESP(); StopHitbox()
    for _,c in ipairs(AllConns) do pcall(function() c:Disconnect() end) end
    AllConns={}
end

