-- ═══════════════ HELPERS ═══════════════
local function New(cls, p)
    local o = Instance.new(cls)
    for k,v in pairs(p or {}) do if k ~= "Parent" then o[k]=v end end
    if p and p.Parent then o.Parent = p.Parent end
    return o
end
local function Corner(o, r) New("UICorner",{CornerRadius=UDim.new(0,r or 8),Parent=o}) end
local function Stroke(o, c, t) New("UIStroke",{Color=c or C.BORDER,Thickness=t or 1,Parent=o}) end
local function Pad(o, l, r, t, b)
    New("UIPadding",{PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),
        PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0),Parent=o})
end
local function Tw(o, p, i) TweenService:Create(o, i or FAST, p):Play() end

