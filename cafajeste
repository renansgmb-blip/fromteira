    local function GetRole(plr)
        local function checkTools(folder)
            if not folder then return nil end
            for _, tool in pairs(folder:GetChildren()) do
                if tool:IsA("Tool") then
                    local name = tool.Name:lower()
                    if name:find("knife") or name:find("blade") then return ROLE_M end
                    if name:find("gun") or name:find("revolver") or name:find("sheriff") then return ROLE_S end
                end
            end
            return nil
        end
        
        local role = checkTools(plr.Character)
        if role then return role end
        
        role = checkTools(plr:FindFirstChild("Backpack"))
        if role then return role end
        
        return ROLE_I
