local function AddDivider(txt, col)
    New("Frame",{Size=UDim2.new(1,0,0,12),BackgroundTransparency=1,Parent=TabList}) -- Espaço grande em cima
    local lbl=New("TextLabel",{
        Size=UDim2.new(1,0,0,16),
        BackgroundTransparency=1,
        Text=txt,
        Font=Enum.Font.GothamBlack, -- Fonte mais destacada
        TextSize=11,
        TextColor3=col or C.MUTED,
        Parent=TabList,
    })
    New("Frame",{Size=UDim2.new(1,0,0,4),BackgroundTransparency=1,Parent=TabList}) -- Pequeno espaço antes dos botões
    return lbl
end

local function SwitchTab(name)
    curTab = name
    for n,pg in pairs(tabPages) do pg.Visible=(n==name) end
    for n,btn in pairs(tabBtns) do
        local isActive = (n==name)
        local acHex = btn:GetAttribute("AC")
        local ac    = acHex and Color3.fromHex(acHex) or C.ACCENT
        if isActive then
            Tw(btn,{BackgroundColor3=ac}); btn.TextColor3=C.WHITE
        else
            Tw(btn,{BackgroundColor3=C.CARD}); btn.TextColor3=C.MUTED
        end
    end
end

local function AddTab(name, accentColor)
    local ac = accentColor or C.ACCENT
    local acHex = "#"..string.format("%02x%02x%02x",
        math.floor(ac.R*255), math.floor(ac.G*255), math.floor(ac.B*255))

    local btn = New("TextButton",{
        Size=UDim2.new(1,0,0,34),
        BackgroundColor3=C.CARD,
        BorderSizePixel=0,
        Text=name,
        Font=Enum.Font.GothamSemibold,
        TextSize=12,
        TextColor3=C.MUTED,
        TextXAlignment=Enum.TextXAlignment.Center,
        Parent=TabList,
    })
    Corner(btn,8)
    btn:SetAttribute("AC", acHex)
    tabBtns[name] = btn

    local pg = New("ScrollingFrame",{
        Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,
        BorderSizePixel=0,
        ScrollBarThickness=3,
        ScrollBarImageColor3=ac,
        CanvasSize=UDim2.new(0,0,0,0),
        AutomaticCanvasSize=Enum.AutomaticSize.Y,
        Visible=false,
        Parent=Content,
    })
    New("UIListLayout",{Padding=UDim.new(0,14),Parent=pg}) 
    Pad(pg,10,16,14,14) 
    tabPages[name] = pg

    btn.MouseButton1Click:Connect(function() SwitchTab(name) end)
    btn.MouseEnter:Connect(function() if curTab~=name then Tw(btn,{BackgroundColor3=C.CARD_H}) end end)
    btn.MouseLeave:Connect(function() if curTab~=name then Tw(btn,{BackgroundColor3=C.CARD}) end end)
end

