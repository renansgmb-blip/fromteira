local function ShakeCard()
    local ox=KC.Position.X.Offset; local oy=KC.Position.Y.Offset
    for i=1,5 do
        KC.Position=UDim2.new(0.5,ox+(i%2==0 and 10 or -10),0.5,oy)
        task.wait(0.045)
    end
    KC.Position=UDim2.new(0.5,ox,0.5,oy)
end

local function TryKey()
    if VALID_KEYS[KB.Text] then
        Tw(KC,{Position=UDim2.new(0.5,-180,0.5,-130),BackgroundTransparency=1},MEDIUM)
        Tw(KS,{BackgroundTransparency=1},MEDIUM)
        task.delay(0.38,function()
            KS:Destroy()
            Win.Visible=true
            SwitchTab("Player")
        end)
    else
        KStat.Text="Chave inválida. Use: Devtest, Leandro ou Renan"
        Stroke(KB, C.RED, 1)
        Tw(KB,{BackgroundColor3=Color3.fromRGB(35,10,10)})
        task.delay(1.2,function()
            Tw(KB,{BackgroundColor3=Color3.fromRGB(10,10,18)})
            KStat.Text=""
            for _,c in pairs(KB:GetChildren()) do if c:IsA("UIStroke") then c:Destroy() end end
            Stroke(KB,C.BORDER,1)
        end)
        ShakeCard()
    end
end

