local function MakeToggle(parent, label, default, cb, ac)
    ac = ac or C.ACCENT
    local card=New("Frame",{Size=UDim2.new(1,0,0,50),BackgroundColor3=C.CARD,BorderSizePixel=0,Parent=parent})
    Corner(card,10); Stroke(card,C.BORDER,1)
    New("TextLabel",{Size=UDim2.new(1,-68,1,0),Position=UDim2.new(0,14,0,0),Text=label,
        Font=Enum.Font.GothamSemibold,TextSize=13,TextColor3=C.TEXT,
        TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,Parent=card})
    local track=New("Frame",{Size=UDim2.new(0,42,0,24),Position=UDim2.new(1,-56,0.5,-12),
        BackgroundColor3=default and ac or C.BORDER,BorderSizePixel=0,Parent=card})
    Corner(track,12)
    local knob=New("Frame",{Size=UDim2.new(0,20,0,20),
        Position=UDim2.new(0,default and 20 or 2,0,2),BackgroundColor3=C.WHITE,BorderSizePixel=0,Parent=track})
    Corner(knob,10)
    local on=default
    local cb2=New("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",Parent=card})
    cb2.MouseButton1Click:Connect(function()
        on=not on
        Tw(track,{BackgroundColor3=on and ac or C.BORDER})
        Tw(knob,{Position=UDim2.new(0,on and 20 or 2,0,2)},SPRING)
        cb(on)
    end)
    card.MouseEnter:Connect(function() Tw(card,{BackgroundColor3=C.CARD_H}) end)
    card.MouseLeave:Connect(function() Tw(card,{BackgroundColor3=C.CARD}) end)
    return card
end

local function MakeSlider(parent, label, min, max, default, cb, ac)
    ac=ac or C.ACCENT
    local card=New("Frame",{Size=UDim2.new(1,0,0,70),BackgroundColor3=C.CARD,BorderSizePixel=0,Parent=parent})
    Corner(card,10); Stroke(card,C.BORDER,1)
    New("TextLabel",{Size=UDim2.new(0.65,0,0,28),Position=UDim2.new(0,14,0,0),Text=label,
        Font=Enum.Font.GothamSemibold,TextSize=12,TextColor3=C.TEXT,
        TextXAlignment=Enum.TextXAlignment.Left,BackgroundTransparency=1,Parent=card})
    local vl=New("TextLabel",{Size=UDim2.new(0.35,-14,0,28),Position=UDim2.new(0.65,0,0,0),
        Text=tostring(default),Font=Enum.Font.GothamBold,TextSize=12,TextColor3=ac,
        TextXAlignment=Enum.TextXAlignment.Right,BackgroundTransparency=1,Parent=card})
    local bg=New("Frame",{Size=UDim2.new(1,-28,0,6),Position=UDim2.new(0,14,0,46),
        BackgroundColor3=C.BORDER,BorderSizePixel=0,Parent=card})
    Corner(bg,3)
    local fill=New("Frame",{Size=UDim2.new((default-min)/(max-min),0,1,0),BackgroundColor3=ac,BorderSizePixel=0,Parent=bg})
    Corner(fill,3)
    local thumb=New("Frame",{Size=UDim2.new(0,14,0,14),
        Position=UDim2.new((default-min)/(max-min),-7,0.5,-7),BackgroundColor3=C.WHITE,BorderSizePixel=0,Parent=bg})
    Corner(thumb,7)
    local dr=false
    local function upd(x)
        local r=math.clamp((x-bg.AbsolutePosition.X)/bg.AbsoluteSize.X,0,1)
        local v=math.floor(min+r*(max-min))
        vl.Text=tostring(v)
        Tw(fill,{Size=UDim2.new(r,0,1,0)}); Tw(thumb,{Position=UDim2.new(r,-7,0.5,-7)})
        cb(v)
    end
    bg.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=true;upd(i.Position.X) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dr=false end end)
    UserInputService.InputChanged:Connect(function(i) if dr and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end end)
    return card
end

local function MakeBtn(parent, label, cb, bg2)
    local btn=New("TextButton",{Size=UDim2.new(1,0,0,44),BackgroundColor3=bg2 or C.CARD,
        BorderSizePixel=0,Text=label,Font=Enum.Font.GothamSemibold,TextSize=13,
        TextColor3=bg2 and C.WHITE or C.TEXT,Parent=parent})
    Corner(btn,10)
    if not bg2 then Stroke(btn,C.BORDER,1) end
    btn.MouseEnter:Connect(function() Tw(btn,{BackgroundColor3=(bg2 or C.CARD):Lerp(C.WHITE,0.1)}) end)
    btn.MouseLeave:Connect(function() Tw(btn,{BackgroundColor3=bg2 or C.CARD}) end)
    btn.MouseButton1Click:Connect(cb)
    return btn
end

