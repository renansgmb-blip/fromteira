-- ╔══════════════════════════════════════════════╗
-- ║   ASSASSINOS VS XERIFES - Script Hub         ║
-- ║   🎯 AimLock + ESP + 🍀 Auto Trevo          ║
-- ║   T=Aim  E=ESP  I=Lista  G=Trevo            ║
-- ╚══════════════════════════════════════════════╝

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Camera      = workspace.CurrentCamera

local Config = {
    AimEnabled       = false,
    SmoothFactor     = 1,
    MaxDistance      = 500,
    AimPart          = "HumanoidRootPart",
    ToggleKey        = Enum.KeyCode.T,
    BreakSensitivity = 1.5,
    BreakFrames      = 1,
    FovEnabled       = true,
    FovSize          = 80,
    EspEnabled       = false,
    EspToggleKey     = Enum.KeyCode.E,
    EspBoxColor      = Color3.fromRGB(0, 200, 255),
    EspHealthBar     = true,
    EspDistance      = true,
    EspMaxDist       = 600,
    WhitelistKey     = Enum.KeyCode.I,
    WhitelistCount   = 4,
    WhitelistUpdate  = 1.5,
    CloverEnabled    = false,
    CloverTeleport   = true,
    CloverDelay      = 0.12,
    CloverKey        = Enum.KeyCode.G,
}

local Target         = nil
local AimConnection  = nil
local EspObjects     = {}
local FovGui         = nil
local FovRing        = nil
local Whitelist      = {}
local NearbyList     = {}
local lastCamCF      = Camera.CFrame
local breakCounter   = 0
local lastListUpdate = 0
local cloverLoop     = nil
local totalTrevos    = 0
local ActiveTab      = "AIM"

-- ═══════════════════════════════
--     UTILITÁRIOS
-- ═══════════════════════════════

local function GetMyRoot()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function IsAlive(player)
    if not player then return false end
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function GetDistTo(player)
    local myRoot = GetMyRoot()
    if not myRoot then return math.huge end
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return math.huge end
    return (root.Position - myRoot.Position).Magnitude
end

local function IsInFov(player)
    if not Config.FovEnabled then return true end
    local char = player.Character
    if not char then return false end
    local root = char:FindFirstChild(Config.AimPart) or char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
    if not onScreen then return false end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    return (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude <= Config.FovSize
end

-- ═══════════════════════════════
--     FOV
-- ═══════════════════════════════

local function CreateFovCircle()
    if FovGui then FovGui:Destroy() end
    FovGui = Instance.new("ScreenGui")
    FovGui.Name = "FovCircleGui"; FovGui.ResetOnSpawn = false
    FovGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling; FovGui.DisplayOrder = 998
    pcall(function() FovGui.Parent = game:GetService("CoreGui") end)
    if not FovGui.Parent then FovGui.Parent = LocalPlayer:WaitForChild("PlayerGui") end
    local container = Instance.new("Frame", FovGui)
    container.Size = UDim2.new(0,0,0,0); container.Position = UDim2.new(0.5,0,0.5,0)
    container.BackgroundTransparency = 1; container.BorderSizePixel = 0
    FovRing = Instance.new("Frame", container)
    local d = Config.FovSize * 2
    FovRing.Size = UDim2.new(0,d,0,d)
    FovRing.Position = UDim2.new(0,-Config.FovSize,0,-Config.FovSize)
    FovRing.BackgroundTransparency = 1; FovRing.BorderSizePixel = 0
    Instance.new("UICorner", FovRing).CornerRadius = UDim.new(1,0)
    local ring = Instance.new("UIStroke", FovRing)
    ring.Color = Color3.fromRGB(255,255,255); ring.Thickness = 1.5; ring.Transparency = 0.4
end

local function UpdateFovCircle()
    if not FovRing or not FovRing.Parent then CreateFovCircle() end
    FovGui.Enabled = Config.AimEnabled and Config.FovEnabled
    local d = Config.FovSize * 2
    FovRing.Size = UDim2.new(0,d,0,d)
    FovRing.Position = UDim2.new(0,-Config.FovSize,0,-Config.FovSize)
end

-- ═══════════════════════════════
--     NEARBY LIST
-- ═══════════════════════════════

local function UpdateNearbyList()
    local candidates = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local dist = GetDistTo(player)
        if dist <= Config.MaxDistance then
            table.insert(candidates, { player = player, dist = dist })
        end
    end
    table.sort(candidates, function(a, b) return a.dist < b.dist end)
    NearbyList = {}
    for i = 1, math.min(Config.WhitelistCount, #candidates) do
        table.insert(NearbyList, candidates[i])
    end
    if RefreshWhitelistUI then RefreshWhitelistUI() end
end

-- ═══════════════════════════════
--     AIM
-- ═══════════════════════════════

local function GetNearestPlayer()
    local nearest     = nil
    local nearestDist = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if Whitelist[player.Name] then continue end
        local char = player.Character
        if not char then continue end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local rootPart = char:FindFirstChild(Config.AimPart) or char:FindFirstChild("HumanoidRootPart")
        if not humanoid or humanoid.Health <= 0 or not rootPart then continue end
        local myRoot = GetMyRoot()
        if not myRoot then continue end
        if (rootPart.Position - myRoot.Position).Magnitude > Config.MaxDistance then continue end
        if not IsInFov(player) then continue end
        local screenPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
        if not onScreen then continue end
        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if screenDist < nearestDist then nearestDist = screenDist; nearest = player end
    end
    return nearest
end

local function StartAimLoop()
    if AimConnection then AimConnection:Disconnect() end
    lastCamCF = Camera.CFrame; breakCounter = 0
    AimConnection = RunService.RenderStepped:Connect(function()
        UpdateFovCircle()
        if not Config.AimEnabled then return end
        local currentCF = Camera.CFrame
        local dot = math.clamp(currentCF.LookVector:Dot(lastCamCF.LookVector), -1, 1)
        local angleDelta = math.deg(math.acos(dot))
        lastCamCF = currentCF
        if angleDelta > Config.BreakSensitivity then breakCounter = breakCounter + 1
        else breakCounter = math.max(0, breakCounter - 1) end
        if breakCounter >= Config.BreakFrames then
            Target = nil; breakCounter = 0; lastCamCF = Camera.CFrame
        end
        if not IsAlive(Target) or (Target and Whitelist[Target.Name]) or (Target and not IsInFov(Target)) then
            Target = GetNearestPlayer()
            if UpdateGUI then UpdateGUI() end
            if not Target then return end
        end
        local char = Target.Character
        local rootPart = char and (char:FindFirstChild(Config.AimPart) or char:FindFirstChild("HumanoidRootPart"))
        if not rootPart then return end
        local camPos = Camera.CFrame.Position
        local direction = (rootPart.Position - camPos).Unit
        Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(camPos, camPos + direction), Config.SmoothFactor)
    end)
end

local function ToggleAim()
    Config.AimEnabled = not Config.AimEnabled
    if Config.AimEnabled then Target = GetNearestPlayer(); lastCamCF = Camera.CFrame; breakCounter = 0
    else Target = nil end
    UpdateFovCircle()
    if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     ESP
-- ═══════════════════════════════

local function CreateEspForPlayer(player)
    local obj = {}
    local hl = Instance.new("SelectionBox")
    hl.LineThickness = 0.04; hl.Color3 = Config.EspBoxColor
    hl.SurfaceTransparency = 1; hl.SurfaceColor3 = Config.EspBoxColor
    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(0,110,0,50); bb.StudsOffset = Vector3.new(0,3,0)
    bb.AlwaysOnTop = true; bb.ResetOnSpawn = false
    local nl = Instance.new("TextLabel", bb)
    nl.Size = UDim2.new(1,0,0.44,0); nl.BackgroundTransparency = 1
    nl.TextColor3 = Color3.fromRGB(255,255,255); nl.TextStrokeTransparency = 0.5
    nl.TextStrokeColor3 = Color3.new(0,0,0); nl.Font = Enum.Font.GothamBold
    nl.TextSize = 13; nl.Text = player.Name
    local il = Instance.new("TextLabel", bb)
    il.Size = UDim2.new(1,0,0.36,0); il.Position = UDim2.new(0,0,0.44,0)
    il.BackgroundTransparency = 1; il.TextColor3 = Color3.fromRGB(0,255,160)
    il.TextStrokeTransparency = 0.5; il.TextStrokeColor3 = Color3.new(0,0,0)
    il.Font = Enum.Font.Gotham; il.TextSize = 11; il.Text = ""
    obj.hl = hl; obj.bb = bb; obj.il = il
    local function attach()
        local char = player.Character
        if not char then return end
        hl.Adornee = char; hl.Parent = workspace
        bb.Adornee = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChildOfClass("BasePart")
        bb.Parent = char
    end
    attach(); player.CharacterAdded:Connect(attach)
    obj.conn = RunService.Heartbeat:Connect(function()
        local char = player.Character
        if not char then return end
        local hum = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        local myRoot = GetMyRoot()
        if not hum or not root or not myRoot then return end
        local dist = math.floor((root.Position - myRoot.Position).Magnitude)
        if dist > Config.EspMaxDist then hl.Parent = nil; bb.Parent = nil; return end
        if hl.Parent ~= workspace then hl.Parent = workspace end
        if bb.Parent ~= char then bb.Parent = char end
        local hp = hum.Health / hum.MaxHealth
        if Target and Target == player then hl.Color3 = Color3.fromRGB(255,50,50)
        elseif Whitelist[player.Name] then hl.Color3 = Color3.fromRGB(0,255,100)
        elseif hp < 0.35 then hl.Color3 = Color3.fromRGB(255,100,0)
        else hl.Color3 = Config.EspBoxColor end
        local info = ""
        if Config.EspHealthBar then info = info .. string.format("♥%d%%", math.floor(hp*100)) end
        if Config.EspDistance   then info = info .. string.format("  %dm", dist) end
        if Whitelist[player.Name] then info = info .. "  ✅" end
        il.Text = info
    end)
    return obj
end

local function ClearEsp()
    for _, obj in pairs(EspObjects) do
        if obj.hl   then pcall(function() obj.hl:Destroy()     end) end
        if obj.bb   then pcall(function() obj.bb:Destroy()     end) end
        if obj.conn then pcall(function() obj.conn:Disconnect() end) end
    end
    EspObjects = {}
end

local function ToggleEsp()
    Config.EspEnabled = not Config.EspEnabled
    if Config.EspEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then EspObjects[p] = CreateEspForPlayer(p) end
        end
        Players.PlayerAdded:Connect(function(p) if Config.EspEnabled then EspObjects[p] = CreateEspForPlayer(p) end end)
        Players.PlayerRemoving:Connect(function(p)
            if EspObjects[p] then
                local o = EspObjects[p]
                if o.hl then pcall(function() o.hl:Destroy() end) end
                if o.bb then pcall(function() o.bb:Destroy() end) end
                if o.conn then pcall(function() o.conn:Disconnect() end) end
                EspObjects[p] = nil
            end
        end)
    else ClearEsp() end
    if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     AUTO TREVO
-- ═══════════════════════════════

local function GetAllClovers()
    local clovers = {}
    local spawnables = workspace:FindFirstChild("Spawnables")
    local client = spawnables and spawnables:FindFirstChild("SpawnablesClient")
    local container = client or spawnables
    if container then
        for _, v in ipairs(container:GetChildren()) do
            if v.Name == "clover" and v:IsA("BasePart") then
                table.insert(clovers, v)
            end
        end
    end
    return clovers
end

local function GetNearestClover()
    local root = GetMyRoot()
    if not root then return nil end
    local nearest = nil; local nearDist = math.huge
    for _, c in ipairs(GetAllClovers()) do
        local dist = (c.Position - root.Position).Magnitude
        if dist < nearDist then nearDist = dist; nearest = c end
    end
    return nearest
end

local function StartCloverLoop()
    if cloverLoop then return end
    cloverLoop = task.spawn(function()
        while Config.CloverEnabled do
            local root = GetMyRoot()
            if not root then task.wait(0.5); continue end
            local clover = GetNearestClover()
            if clover and clover.Parent then
                if Config.CloverTeleport then
                    root.CFrame = CFrame.new(clover.Position + Vector3.new(0, 3, 0))
                else
                    local char = LocalPlayer.Character
                    local hum = char and char:FindFirstChildOfClass("Humanoid")
                    if hum then
                        hum:MoveTo(clover.Position)
                        local t = tick()
                        repeat task.wait(0.05)
                        until not clover.Parent
                           or (GetMyRoot() and (GetMyRoot().Position - clover.Position).Magnitude < 4)
                           or tick() - t > 5
                    end
                end
                totalTrevos = totalTrevos + 1
                if UpdateGUI then UpdateGUI() end
            else task.wait(0.4) end
            task.wait(Config.CloverDelay)
        end
        cloverLoop = nil
    end)
end

local function ToggleClover()
    Config.CloverEnabled = not Config.CloverEnabled
    if Config.CloverEnabled then StartCloverLoop() else cloverLoop = nil end
    if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     CLEANUP
-- ═══════════════════════════════

local function Cleanup()
    Config.AimEnabled = false; Config.EspEnabled = false; Config.CloverEnabled = false
    if AimConnection then AimConnection:Disconnect() end
    ClearEsp()
    if FovGui then pcall(function() FovGui:Destroy() end); FovGui = nil; FovRing = nil end
    cloverLoop = nil
    pcall(function() Camera.CameraType = Enum.CameraType.Custom end)
end

