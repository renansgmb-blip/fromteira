-- ════════════════════════════════════════
--  UPDATE GUI
-- ════════════════════════════════════════

function UpdateGUI()
    -- AIM badge
    if Config.AimEnabled then
        AimBadgeLbl.Text = "LIGADO"; AimBadge.BackgroundColor3 = Color3.fromRGB(0,130,60)
        AimBtn.BackgroundColor3 = Color3.fromRGB(20,160,70); AimBtn.Text = "🔒  DESATIVAR AIM LOCK  [ T ]"
        AimStatusLbl.TextColor3 = Color3.fromRGB(0,255,160)
    else
        AimBadgeLbl.Text = "OFF"; AimBadge.BackgroundColor3 = Color3.fromRGB(80,30,30)
        AimBtn.BackgroundColor3 = Color3.fromRGB(0,110,220); AimBtn.Text = "⚡  ATIVAR AIM LOCK  [ T ]"
        AimStatusLbl.TextColor3 = Color3.fromRGB(200,200,255)
        TargetLbl.Text = "Sem alvo"; TargetLbl.TextColor3 = Color3.fromRGB(80,80,120)
    end
    -- ESP badge
    if Config.EspEnabled then
        EspBadgeLbl.Text = "LIGADO"; EspBadge.BackgroundColor3 = Color3.fromRGB(100,0,200)
        EspBtn.BackgroundColor3 = Color3.fromRGB(120,0,220); EspBtn.Text = "🚫  DESATIVAR ESP  [ E ]"
        EspStatusLbl.TextColor3 = Color3.fromRGB(180,100,255)
    else
        EspBadgeLbl.Text = "OFF"; EspBadge.BackgroundColor3 = Color3.fromRGB(80,30,30)
        EspBtn.BackgroundColor3 = Color3.fromRGB(90,0,180); EspBtn.Text = "🔍  ATIVAR ESP  [ E ]"
        EspStatusLbl.TextColor3 = Color3.fromRGB(200,200,255)
    end
    -- TREVO badge
    if Config.CloverEnabled then
        TrBadgeLbl.Text = "LIGADO"; TrBadge.BackgroundColor3 = Color3.fromRGB(0,140,50)
        TrBtn.BackgroundColor3 = Color3.fromRGB(160,30,30); TrBtn.Text = "⛔  DESATIVAR TREVO  [ G ]"
        TrStatusLbl.TextColor3 = Color3.fromRGB(0,255,120)
    else
        TrBadgeLbl.Text = "OFF"; TrBadge.BackgroundColor3 = Color3.fromRGB(80,30,30)
        TrBtn.BackgroundColor3 = Color3.fromRGB(0,120,45); TrBtn.Text = "🍀  ATIVAR AUTO TREVO  [ G ]"
        TrStatusLbl.TextColor3 = Color3.fromRGB(200,200,255)
    end
    TrCountLbl.Text = "Coletados: "..totalTrevos
end

-- Heartbeat updates
RunService.Heartbeat:Connect(function()
    if Config.AimEnabled then
        if Target and IsAlive(Target) then
            TargetLbl.Text = "Travado: "..Target.Name
            TargetLbl.TextColor3 = Color3.fromRGB(0,255,160)
        else
            TargetLbl.Text = "Procurando alvo..."
            TargetLbl.TextColor3 = Color3.fromRGB(255,180,0)
        end
    end
    local now = tick()
    if now - lastListUpdate >= Config.WhitelistUpdate then
        lastListUpdate = now
        UpdateNearbyList()
        -- Atualiza trevos no mapa
        local clovers = GetAllClovers()
        TrMapLbl.Text = "📍 Trevos no mapa:  "..#clovers
    end
end)

-- ════════════════════════════════════════
--  MINIMIZAR / FECHAR
-- ════════════════════════════════════════
local minimized = false
local Body = Instance.new("Frame", Main) -- container pra minimizar
Body.Size = UDim2.new(1,0,1,-52); Body.Position = UDim2.new(0,0,0,52)
Body.BackgroundTransparency = 1; Body.ClipsDescendants = false

MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    for _, page in pairs(TabPages) do page.Visible = not minimized and (page == TabPages[ActiveTab]) end
    TabBar.Visible = not minimized
    StatusBar.Visible = not minimized
    TweenService:Create(Main, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {
        Size = minimized and UDim2.new(0,340,0,52) or UDim2.new(0,340,0,480)
    }):Play()
    MinBtn.Text = minimized and "▢" or "─"
end)

CloseBtn.MouseButton1Click:Connect(function()
    Cleanup()
    TweenService:Create(Main, TweenInfo.new(0.2), {Size=UDim2.new(0,0,0,0), BackgroundTransparency=1}):Play()
    task.wait(0.25); ScreenGui:Destroy()
end)

-- ════════════════════════════════════════
--  BOTÕES MOBILE
-- ════════════════════════════════════════
local function MkMob(text, x, r, g, b, sr, sg, sb)
    local btn = Instance.new("TextButton", ScreenGui)
    btn.Size = UDim2.new(0,52,0,52); btn.Position = UDim2.new(0,x,1,-72)
    btn.BackgroundColor3 = Color3.fromRGB(r,g,b); btn.Text = text
    btn.TextSize = 22; btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0; btn.ZIndex = 10
    Instance.new("UICorner", btn).CornerRadius = UDim.new(1,0)
    local s = Instance.new("UIStroke", btn)
    s.Color = Color3.fromRGB(sr,sg,sb); s.Thickness = 2
    return btn
end

local MobAim  = MkMob("🎯", 20,  0,130,220, 0,200,255)
local MobEsp  = MkMob("👁", 80, 90,  0,180, 170,80,255)
local MobWL   = MkMob("👥",140, 28,  0, 90, 90,80,200)
local MobClvr = MkMob("🍀",200,  0,150, 55, 0,230, 90)

-- ════════════════════════════════════════
--  CONTROLES
-- ════════════════════════════════════════
AimBtn.MouseButton1Click:Connect(ToggleAim)
EspBtn.MouseButton1Click:Connect(ToggleEsp)
TrBtn.MouseButton1Click:Connect(ToggleClover)
MobAim.MouseButton1Click:Connect(ToggleAim)
MobEsp.MouseButton1Click:Connect(ToggleEsp)
MobWL.MouseButton1Click:Connect(function() SetTab("LISTA") end)
MobClvr.MouseButton1Click:Connect(ToggleClover)

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Config.ToggleKey    then ToggleAim()    end
    if input.KeyCode == Config.EspToggleKey then ToggleEsp()    end
    if input.KeyCode == Config.WhitelistKey then SetTab("LISTA") end
    if input.KeyCode == Config.CloverKey    then ToggleClover() end
end)

