function UpdateGUI()
    -- AIM
    if Config.AimEnabled then
        AimBgL.Text="LIGADO"; AimBg.BackgroundColor3=Color3.fromRGB(0,130,60)
        AimBtn.BackgroundColor3=Color3.fromRGB(20,155,70); AimBtn.Text="🔒  DESATIVAR AIM LOCK  [ T ]"
        AimTL.TextColor3=Color3.fromRGB(0,255,160)
    else
        AimBgL.Text="OFF"; AimBg.BackgroundColor3=Color3.fromRGB(70,25,25)
        AimBtn.BackgroundColor3=Color3.fromRGB(0,110,210); AimBtn.Text="⚡  ATIVAR AIM LOCK  [ T ]"
        AimTL.TextColor3=Color3.fromRGB(200,200,255)
        TgtLbl.Text="Sem alvo"; TgtLbl.TextColor3=Color3.fromRGB(60,60,100)
    end
    -- ESP
    if Config.EspEnabled then
        EspBgL.Text="LIGADO"; EspBg.BackgroundColor3=Color3.fromRGB(100,0,200)
        EspBtn.BackgroundColor3=Color3.fromRGB(110,0,220); EspBtn.Text="🚫  DESATIVAR ESP  [ E ]"
        EspTL.TextColor3=Color3.fromRGB(180,100,255)
    else
        EspBgL.Text="OFF"; EspBg.BackgroundColor3=Color3.fromRGB(70,25,25)
        EspBtn.BackgroundColor3=Color3.fromRGB(90,0,180); EspBtn.Text="🔍  ATIVAR ESP  [ E ]"
        EspTL.TextColor3=Color3.fromRGB(200,200,255)
    end
    -- HITBOX
    if Config.HitboxEnabled then
        HbBgL.Text="LIGADO"; HbBg.BackgroundColor3=Color3.fromRGB(180,40,40)
        HbBtn.BackgroundColor3=Color3.fromRGB(155,30,30); HbBtn.Text="⛔  DESATIVAR HITBOX  [ H ]"
        HbTL.TextColor3=Color3.fromRGB(255,100,100)
    else
        HbBgL.Text="OFF"; HbBg.BackgroundColor3=Color3.fromRGB(70,25,25)
        HbBtn.BackgroundColor3=Color3.fromRGB(185,38,38); HbBtn.Text="📦  ATIVAR HITBOX  [ H ]"
        HbTL.TextColor3=Color3.fromRGB(200,200,255)
    end
    -- TREVO
    if Config.CloverEnabled then
        TrBgL.Text="LIGADO"; TrBg.BackgroundColor3=Color3.fromRGB(0,140,50)
        TrBtn.BackgroundColor3=Color3.fromRGB(155,28,28); TrBtn.Text="⛔  DESATIVAR TREVO  [ G ]"
        TrTL.TextColor3=Color3.fromRGB(0,255,120)
    else
        TrBgL.Text="OFF"; TrBg.BackgroundColor3=Color3.fromRGB(70,25,25)
        TrBtn.BackgroundColor3=Color3.fromRGB(0,120,45); TrBtn.Text="🍀  ATIVAR AUTO TREVO  [ G ]"
        TrTL.TextColor3=Color3.fromRGB(200,200,255)
    end
    TrCL.Text="Coletados: "..totalTrevos
end

TC(RunService.Heartbeat:Connect(function()
    if Destroyed then return end
    if Config.AimEnabled then
        if Target and Alive(Target) then
            TgtLbl.Text="Travado: "..Target.Name; TgtLbl.TextColor3=Color3.fromRGB(0,255,160)
        else
            TgtLbl.Text="Procurando..."; TgtLbl.TextColor3=Color3.fromRGB(255,175,0)
        end
    end
    local now=tick()
    if now-lastListUpdate>=Config.WhitelistUpdate then
        lastListUpdate=now
        NearbyList=NearPlayers(Config.WhitelistCount)
        HbNearList=NearPlayers(4)
        if RefreshWhitelistUI then RefreshWhitelistUI() end
        if RefreshHitboxListUI then RefreshHitboxListUI() end
        local cl=GetClovers()
        if TrMapLbl and TrMapLbl.Parent then TrMapLbl.Text="📍 Trevos no mapa:  "..#cl end
    end
end))

-- ══════════════════════════════
--  MINIMIZAR / FECHAR
-- ══════════════════════════════
local minimized=false
MinB.MouseButton1Click:Connect(function()
    minimized=not minimized
    for pn,pg in pairs(TPages) do pg.Visible=not minimized and (pn==ActiveTab) end
    TabBar.Visible=not minimized; SBar.Visible=not minimized
    TweenService:Create(Win,TweenInfo.new(0.2,Enum.EasingStyle.Quad),{
        Size=minimized and UDim2.new(0,380,0,58) or UDim2.new(0,380,0,540)
    }):Play()
    MinB.Text=minimized and "▢" or "─"
end)

CloseB.MouseButton1Click:Connect(function()
    Cleanup()
    TweenService:Create(Win,TweenInfo.new(0.18),{Size=UDim2.new(0,0,0,0),BackgroundTransparency=1}):Play()
    task.wait(0.2); SG:Destroy()
end)

-- ══════════════════════════════
--  MOBILE
-- ══════════════════════════════
local function Mob(ic,x,r,g,b,sr,sg,sb)
    local b=Instance.new("TextButton",SG)
    b.Size=UDim2.new(0,52,0,52); b.Position=UDim2.new(0,x,1,-68)
    b.BackgroundColor3=Color3.fromRGB(r,g,b); b.Text=ic
    b.TextSize=20; b.Font=Enum.Font.GothamBold
    b.BorderSizePixel=0; b.ZIndex=10
    Instance.new("UICorner",b).CornerRadius=UDim.new(1,0)
    local s=Instance.new("UIStroke",b); s.Color=Color3.fromRGB(sr,sg,sb); s.Thickness=2
    return b
end
local MA=Mob("🎯",16, 0,120,210, 0,180,255)
local ME=Mob("👁", 76,90,  0,175,155,65,255)
local MH=Mob("📦",136,180,40, 40,255,75, 75)
local MG=Mob("🍀",196, 0,145, 50,  0,215,80)
local MI=Mob("👥",256,26,  0, 85, 80,65,185)

