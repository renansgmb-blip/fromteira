-- ════════════════════════════════════════
--  REFRESH WHITELIST
-- ════════════════════════════════════════

function RefreshWhitelistUI()
    for _, c in ipairs(WLList:GetChildren()) do c:Destroy() end
    if #NearbyList == 0 then
        local el = Instance.new("TextLabel", WLList)
        el.Size = UDim2.new(1,0,0,40); el.BackgroundTransparency = 1
        el.Text = "Nenhum jogador próximo"; el.TextColor3 = Color3.fromRGB(60,60,100)
        el.TextSize = 12; el.Font = Enum.Font.Gotham
        return
    end
    for i, entry in ipairs(NearbyList) do
        local player = entry.player
        local dist   = math.floor(entry.dist)
        local isWL   = Whitelist[player.Name] == true

        local row = Instance.new("Frame", WLList)
        row.Size = UDim2.new(1,0,0,52); row.Position = UDim2.new(0,0,0,(i-1)*58)
        row.BackgroundColor3 = isWL and Color3.fromRGB(0,60,20) or Color3.fromRGB(20,20,34)
        row.BorderSizePixel = 0
        Instance.new("UICorner", row).CornerRadius = UDim.new(0,10)
        local rs = Instance.new("UIStroke", row)
        rs.Color = isWL and Color3.fromRGB(0,180,60) or Color3.fromRGB(35,35,58); rs.Thickness = 1

        -- Avatar placeholder
        local av = Instance.new("Frame", row)
        av.Size = UDim2.new(0,36,0,36); av.Position = UDim2.new(0,8,0.5,-18)
        av.BackgroundColor3 = isWL and Color3.fromRGB(0,100,40) or Color3.fromRGB(30,30,55)
        av.BorderSizePixel = 0
        Instance.new("UICorner", av).CornerRadius = UDim.new(1,0)
        local avLbl = Instance.new("TextLabel", av)
        avLbl.Size = UDim2.new(1,0,1,0); avLbl.BackgroundTransparency = 1
        avLbl.Text = string.upper(string.sub(player.Name,1,1))
        avLbl.TextColor3 = Color3.fromRGB(255,255,255); avLbl.TextSize = 15; avLbl.Font = Enum.Font.GothamBold

        local nameLbl = Instance.new("TextLabel", row)
        nameLbl.Size = UDim2.new(1,-120,0,20); nameLbl.Position = UDim2.new(0,52,0,7)
        nameLbl.BackgroundTransparency = 1; nameLbl.Text = player.Name
        nameLbl.TextColor3 = isWL and Color3.fromRGB(0,255,120) or Color3.fromRGB(220,220,255)
        nameLbl.TextSize = 13; nameLbl.Font = Enum.Font.GothamBold; nameLbl.TextXAlignment = Enum.TextXAlignment.Left

        local distLbl = Instance.new("TextLabel", row)
        distLbl.Size = UDim2.new(1,-120,0,16); distLbl.Position = UDim2.new(0,52,0,28)
        distLbl.BackgroundTransparency = 1; distLbl.Text = "📍 "..dist.." metros"
        distLbl.TextColor3 = Color3.fromRGB(80,120,200); distLbl.TextSize = 11
        distLbl.Font = Enum.Font.Gotham; distLbl.TextXAlignment = Enum.TextXAlignment.Left

        local ignorBtn = Instance.new("TextButton", row)
        ignorBtn.Size = UDim2.new(0,68,0,28); ignorBtn.Position = UDim2.new(1,-76,0.5,-14)
        ignorBtn.BackgroundColor3 = isWL and Color3.fromRGB(0,130,50) or Color3.fromRGB(40,40,70)
        ignorBtn.Text = isWL and "✅ ON" or "Ignorar"
        ignorBtn.TextColor3 = Color3.fromRGB(255,255,255); ignorBtn.TextSize = 11
        ignorBtn.Font = Enum.Font.GothamBold; ignorBtn.BorderSizePixel = 0
        Instance.new("UICorner", ignorBtn).CornerRadius = UDim.new(0,7)

        ignorBtn.MouseButton1Click:Connect(function()
            if Whitelist[player.Name] then Whitelist[player.Name] = nil
            else
                Whitelist[player.Name] = true
                if Target and Target == player then Target = GetNearestPlayer(); if UpdateGUI then UpdateGUI() end end
            end
            RefreshWhitelistUI()
        end)
    end
end

