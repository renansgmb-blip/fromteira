-- Lista ignorar hitbox
SecLbl(PH,"IGNORAR JOGADORES",8)
local HbListCard=Card(PH,228,9)
local HbListFrame=Instance.new("Frame",HbListCard)
HbListFrame.Size=UDim2.new(1,-16,1,-10); HbListFrame.Position=UDim2.new(0,8,0,6)
HbListFrame.BackgroundTransparency=1

function RefreshHitboxListUI()
    for _,c in ipairs(HbListFrame:GetChildren()) do c:Destroy() end
    if #HbNearList==0 then
        local el=Instance.new("TextLabel",HbListFrame)
        el.Size=UDim2.new(1,0,0,30); el.BackgroundTransparency=1
        el.Text="Nenhum jogador próximo"; el.TextColor3=Color3.fromRGB(50,50,85)
        el.TextSize=12; el.Font=Enum.Font.Gotham
        return
    end
    for i,e in ipairs(HbNearList) do
        local p=e.player; local d=math.floor(e.dist)
        local ign=HitboxWhitelist[p.Name]==true
        local row=Instance.new("Frame",HbListFrame)
        row.Size=UDim2.new(1,0,0,46); row.Position=UDim2.new(0,0,0,(i-1)*52)
        row.BackgroundColor3=ign and Color3.fromRGB(0,55,20) or Color3.fromRGB(18,18,30)
        row.BorderSizePixel=0
        Instance.new("UICorner",row).CornerRadius=UDim.new(0,9)
        local rs=Instance.new("UIStroke",row)
        rs.Color=ign and Color3.fromRGB(0,160,55) or Color3.fromRGB(28,28,48); rs.Thickness=1
        local av=Instance.new("Frame",row)
        av.Size=UDim2.new(0,32,0,32); av.Position=UDim2.new(0,7,0.5,-16)
        av.BackgroundColor3=ign and Color3.fromRGB(0,100,40) or Color3.fromRGB(185,38,38)
        av.BorderSizePixel=0; Instance.new("UICorner",av).CornerRadius=UDim.new(1,0)
        local avl=Instance.new("TextLabel",av)
        avl.Size=UDim2.new(1,0,1,0); avl.BackgroundTransparency=1
        avl.Text=string.upper(string.sub(p.Name,1,1))
        avl.TextColor3=Color3.fromRGB(255,255,255); avl.TextSize=14; avl.Font=Enum.Font.GothamBold
        local nl=Instance.new("TextLabel",row)
        nl.Size=UDim2.new(1,-110,0,18); nl.Position=UDim2.new(0,46,0,6)
        nl.BackgroundTransparency=1; nl.Text=p.Name
        nl.TextColor3=ign and Color3.fromRGB(0,255,120) or Color3.fromRGB(220,220,255)
        nl.TextSize=12; nl.Font=Enum.Font.GothamBold; nl.TextXAlignment=Enum.TextXAlignment.Left
        local dl=Instance.new("TextLabel",row)
        dl.Size=UDim2.new(1,-110,0,14); dl.Position=UDim2.new(0,46,0,25)
        dl.BackgroundTransparency=1; dl.Text=d.."m"
        dl.TextColor3=Color3.fromRGB(65,100,170); dl.TextSize=10
        dl.Font=Enum.Font.Gotham; dl.TextXAlignment=Enum.TextXAlignment.Left
        local ib=Instance.new("TextButton",row)
        ib.Size=UDim2.new(0,62,0,26); ib.Position=UDim2.new(1,-68,0.5,-13)
        ib.BackgroundColor3=ign and Color3.fromRGB(0,120,48) or Color3.fromRGB(38,38,60)
        ib.Text=ign and "✅ ON" or "Ignorar"
        ib.TextColor3=Color3.fromRGB(255,255,255); ib.TextSize=11
        ib.Font=Enum.Font.GothamBold; ib.BorderSizePixel=0
        Instance.new("UICorner",ib).CornerRadius=UDim.new(0,7)
        ib.MouseButton1Click:Connect(function()
            if HitboxWhitelist[p.Name] then HitboxWhitelist[p.Name]=nil
            else HitboxWhitelist[p.Name]=true end
            RefreshHitboxListUI()
        end)
    end
end

