-- ╚══════════════════════════════════════════════╝

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Camera      = workspace.CurrentCamera

-- ═══════════════════════════════
--     CONFIG
-- ═══════════════════════════════
local Config = {
    -- AIM
    AimEnabled       = false,
    SmoothFactor     = 1,
    MaxDistance      = 500,
    AimPart          = "HumanoidRootPart",
    ToggleKey        = Enum.KeyCode.T,
    BreakEnabled     = true,
    BreakSensitivity = 1.5,
    BreakFrames      = 1,
    FovEnabled       = true,
    FovSize          = 80,
    -- ESP
    EspEnabled       = false,
    EspToggleKey     = Enum.KeyCode.E,
    EspBoxColor      = Color3.fromRGB(0,200,255),
    EspHealthBar     = true,
    EspDistance      = true,
    EspMaxDist       = 600,
    -- HITBOX
    HitboxEnabled    = false,
    HitboxToggleKey  = Enum.KeyCode.H,
    HitboxSize       = 50,
    HitboxColor      = BrickColor.new("Really blue"),
    HitboxTransp     = 0.7,
    -- LISTA/WHITELIST
    WhitelistKey     = Enum.KeyCode.I,
    WhitelistCount   = 4,
    WhitelistUpdate  = 1.5,
    -- TREVO
    CloverEnabled    = false,
    CloverTeleport   = true,
    CloverDelay      = 0.12,
    CloverKey        = Enum.KeyCode.G,
}

-- ═══════════════════════════════
--     VARIÁVEIS
-- ═══════════════════════════════
local Target         = nil
local AimConn        = nil
local HitboxConn     = nil
local EspObjects     = {}
local FovGui         = nil
local FovRing        = nil
local Whitelist      = {}
local HitboxWhitelist= {}
local NearbyList     = {}
local HbNearList     = {}
local lastCamCF      = Camera.CFrame
local breakCounter   = 0
local lastListUpdate = 0
local cloverLoop     = nil
local totalTrevos    = 0
local ActiveTab      = "AIM"
local Destroyed      = false
local AllConns       = {}

local function TC(c) table.insert(AllConns,c); return c end

-- ═══════════════════════════════
--     UTILS
-- ═══════════════════════════════
local function Root() local c=LocalPlayer.Character; return c and c:FindFirstChild("HumanoidRootPart") end

local function Alive(p)
    if not p then return false end
    local c=p.Character; if not c then return false end
    local h=c:FindFirstChildOfClass("Humanoid")
    return h and h.Health>0
end

local function Dist(p)
    local r=Root(); if not r then return math.huge end
    local c=p.Character; local rp=c and c:FindFirstChild("HumanoidRootPart")
    if not rp then return math.huge end
    return (rp.Position-r.Position).Magnitude
end

local function InFov(p)
    if not Config.FovEnabled then return true end
    local c=p.Character; if not c then return false end
    local rp=c:FindFirstChild(Config.AimPart) or c:FindFirstChild("HumanoidRootPart")
    if not rp then return false end
    local sp,os=Camera:WorldToViewportPoint(rp.Position)
    if not os then return false end
    local ctr=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    return (Vector2.new(sp.X,sp.Y)-ctr).Magnitude<=Config.FovSize
end

local function NearPlayers(n)
    local out={}
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LocalPlayer then continue end
        if not p.Character then continue end
        local h=p.Character:FindFirstChildOfClass("Humanoid")
        if not h or h.Health<=0 then continue end
        local d=Dist(p)
        if d<=Config.MaxDistance then table.insert(out,{player=p,dist=d}) end
    end
    table.sort(out,function(a,b) return a.dist<b.dist end)
    local res={}
    for i=1,math.min(n or 4,#out) do res[i]=out[i] end
    return res
end

-- ═══════════════════════════════
--     FOV
-- ═══════════════════════════════
local function BuildFov()
    if FovGui then FovGui:Destroy() end
    FovGui=Instance.new("ScreenGui"); FovGui.Name="BananaFov"
    FovGui.ResetOnSpawn=false; FovGui.ZIndexBehavior=Enum.ZIndexBehavior.Sibling
    FovGui.DisplayOrder=998
    pcall(function() FovGui.Parent=game:GetService("CoreGui") end)
    if not FovGui.Parent then FovGui.Parent=LocalPlayer:WaitForChild("PlayerGui") end
    local con=Instance.new("Frame",FovGui)
    con.Size=UDim2.new(0,0,0,0); con.Position=UDim2.new(0.5,0,0.5,0)
    con.BackgroundTransparency=1; con.BorderSizePixel=0
    FovRing=Instance.new("Frame",con)
    local d=Config.FovSize*2
    FovRing.Size=UDim2.new(0,d,0,d); FovRing.Position=UDim2.new(0,-Config.FovSize,0,-Config.FovSize)
    FovRing.BackgroundTransparency=1; FovRing.BorderSizePixel=0
    Instance.new("UICorner",FovRing).CornerRadius=UDim.new(1,0)
    local st=Instance.new("UIStroke",FovRing)
    st.Color=Color3.fromRGB(255,255,255); st.Thickness=1.5; st.Transparency=0.35
end

local function UpdFov()
    if Destroyed then return end
    if not FovRing or not FovRing.Parent then BuildFov() end
    FovGui.Enabled=Config.AimEnabled and Config.FovEnabled
    local d=Config.FovSize*2
    FovRing.Size=UDim2.new(0,d,0,d); FovRing.Position=UDim2.new(0,-Config.FovSize,0,-Config.FovSize)
end

-- ═══════════════════════════════
--     AIM
-- ═══════════════════════════════
local function NearestEnemy()
    local best,bd=nil,math.huge
    local ctr=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LocalPlayer or Whitelist[p.Name] then continue end
        local c=p.Character; if not c then continue end
        local h=c:FindFirstChildOfClass("Humanoid")
        local rp=c:FindFirstChild(Config.AimPart) or c:FindFirstChild("HumanoidRootPart")
        if not h or h.Health<=0 or not rp then continue end
        local r=Root(); if not r then continue end
        if (rp.Position-r.Position).Magnitude>Config.MaxDistance then continue end
        if not InFov(p) then continue end
        local sp,os=Camera:WorldToViewportPoint(rp.Position)
        if not os then continue end
        local sd=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude
        if sd<bd then bd=sd; best=p end
    end
    return best
end

local function StartAim()
    if AimConn then AimConn:Disconnect() end
    lastCamCF=Camera.CFrame; breakCounter=0
    AimConn=TC(RunService.RenderStepped:Connect(function()
        if Destroyed then return end
        UpdFov()
        if not Config.AimEnabled then return end
        if Config.BreakEnabled then
            local cf=Camera.CFrame
            local dot=math.clamp(cf.LookVector:Dot(lastCamCF.LookVector),-1,1)
            local ang=math.deg(math.acos(dot))
            lastCamCF=cf
            if ang>Config.BreakSensitivity then breakCounter=breakCounter+1
            else breakCounter=math.max(0,breakCounter-1) end
            if breakCounter>=Config.BreakFrames then
                Target=nil; breakCounter=0; lastCamCF=Camera.CFrame
            end
        end
        if not Alive(Target) or (Target and Whitelist[Target.Name]) or (Target and not InFov(Target)) then
            Target=NearestEnemy()
            if UpdateGUI then UpdateGUI() end
            if not Target then return end
        end
        local c=Target.Character
        local rp=c and (c:FindFirstChild(Config.AimPart) or c:FindFirstChild("HumanoidRootPart"))
        if not rp then return end
        local cp=Camera.CFrame.Position
        Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(cp,(rp.Position-cp).Unit+cp),Config.SmoothFactor)
    end))
end

local function TogAim()
    Config.AimEnabled=not Config.AimEnabled
    if Config.AimEnabled then Target=NearestEnemy(); lastCamCF=Camera.CFrame; breakCounter=0
    else Target=nil end
    UpdFov(); if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     ESP
-- ═══════════════════════════════
local function MkEsp(p)
    local obj={}
    local hl=Instance.new("SelectionBox")
    hl.LineThickness=0.04; hl.Color3=Config.EspBoxColor
    hl.SurfaceTransparency=1; hl.SurfaceColor3=Config.EspBoxColor
    local bb=Instance.new("BillboardGui")
    bb.Size=UDim2.new(0,110,0,50); bb.StudsOffset=Vector3.new(0,3,0)
    bb.AlwaysOnTop=true; bb.ResetOnSpawn=false
    local nl=Instance.new("TextLabel",bb)
    nl.Size=UDim2.new(1,0,0.44,0); nl.BackgroundTransparency=1
    nl.TextColor3=Color3.fromRGB(255,255,255); nl.TextStrokeTransparency=0.5
    nl.TextStrokeColor3=Color3.new(0,0,0); nl.Font=Enum.Font.GothamBold
    nl.TextSize=13; nl.Text=p.Name
    local il=Instance.new("TextLabel",bb)
    il.Size=UDim2.new(1,0,0.36,0); il.Position=UDim2.new(0,0,0.44,0)
    il.BackgroundTransparency=1; il.TextColor3=Color3.fromRGB(0,255,160)
    il.TextStrokeTransparency=0.5; il.TextStrokeColor3=Color3.new(0,0,0)
    il.Font=Enum.Font.Gotham; il.TextSize=11; il.Text=""
    obj.hl=hl; obj.bb=bb; obj.il=il
    local function att()
        if Destroyed then return end
        local c=p.Character; if not c then return end
        hl.Adornee=c; hl.Parent=workspace
        bb.Adornee=c:FindFirstChild("HumanoidRootPart") or c:FindFirstChildOfClass("BasePart")
        bb.Parent=c
    end
    att(); obj.cc=TC(p.CharacterAdded:Connect(att))
    obj.hc=TC(RunService.Heartbeat:Connect(function()
        if Destroyed then return end
        local c=p.Character; if not c then return end
        local h=c:FindFirstChildOfClass("Humanoid")
        local r=c:FindFirstChild("HumanoidRootPart"); local mr=Root()
        if not h or not r or not mr then return end
        local d=math.floor((r.Position-mr.Position).Magnitude)
        if d>Config.EspMaxDist then hl.Parent=nil; bb.Parent=nil; return end
        if hl.Parent~=workspace then hl.Parent=workspace end
        if bb.Parent~=c then bb.Parent=c end
        local hp=h.Health/h.MaxHealth
        if Target==p then hl.Color3=Color3.fromRGB(255,50,50)
        elseif Whitelist[p.Name] then hl.Color3=Color3.fromRGB(0,255,100)
        elseif hp<0.35 then hl.Color3=Color3.fromRGB(255,100,0)
        else hl.Color3=Config.EspBoxColor end
        local info=""
        if Config.EspHealthBar then info=info..string.format("♥%d%%",math.floor(hp*100)) end
        if Config.EspDistance   then info=info..string.format("  %dm",d) end
        il.Text=info
    end))
    return obj
end

local function ClearEsp()
    for _,o in pairs(EspObjects) do
        if o.hl  then pcall(function() o.hl:Destroy()    end) end
        if o.bb  then pcall(function() o.bb:Destroy()    end) end
        if o.hc  then pcall(function() o.hc:Disconnect() end) end
        if o.cc  then pcall(function() o.cc:Disconnect() end) end
    end
    EspObjects={}
end

local function TogEsp()
    Config.EspEnabled=not Config.EspEnabled
    if Config.EspEnabled then
        for _,p in ipairs(Players:GetPlayers()) do
            if p~=LocalPlayer then EspObjects[p]=MkEsp(p) end
        end
        TC(Players.PlayerAdded:Connect(function(p) if Config.EspEnabled and not Destroyed then EspObjects[p]=MkEsp(p) end end))
        TC(Players.PlayerRemoving:Connect(function(p)
            if EspObjects[p] then
                local o=EspObjects[p]
                if o.hl then pcall(function() o.hl:Destroy() end) end
                if o.bb then pcall(function() o.bb:Destroy() end) end
                if o.hc then pcall(function() o.hc:Disconnect() end) end
                if o.cc then pcall(function() o.cc:Disconnect() end) end
                EspObjects[p]=nil
            end
        end))
    else ClearEsp() end
    if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     HITBOX (método correto)
-- ═══════════════════════════════

local function StartHitbox()
    if HitboxConn then HitboxConn:Disconnect() end
    HitboxConn=TC(RunService.RenderStepped:Connect(function()
        if Destroyed or not Config.HitboxEnabled then return end
        for _,p in ipairs(Players:GetPlayers()) do
            if p==LocalPlayer then continue end
            if HitboxWhitelist[p.Name] then continue end
            pcall(function()
                local c=p.Character; if not c then return end
                local rp=c:FindFirstChild("HumanoidRootPart"); if not rp then return end
                rp.Size=Vector3.new(Config.HitboxSize,Config.HitboxSize,Config.HitboxSize)
                rp.Transparency=Config.HitboxTransp
                rp.BrickColor=Config.HitboxColor
                rp.Material=Enum.Material.Neon
                rp.CanCollide=false
            end)
        end
    end))
end

local function StopHitbox()
    -- Restaura tamanho original ao desativar
    for _,p in ipairs(Players:GetPlayers()) do
        if p==LocalPlayer then continue end
        pcall(function()
            local c=p.Character; if not c then return end
            local rp=c:FindFirstChild("HumanoidRootPart"); if not rp then return end
            rp.Size=Vector3.new(2,2,1)
            rp.Transparency=1
            rp.Material=Enum.Material.SmoothPlastic
            rp.CanCollide=false
        end)
    end
end

local function TogHitbox()
    Config.HitboxEnabled=not Config.HitboxEnabled
    if Config.HitboxEnabled then StartHitbox()
    else StopHitbox() end
    if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     TREVO
-- ═══════════════════════════════
local function GetClovers()
    local out={}
    local s=workspace:FindFirstChild("Spawnables")
    local cl=s and s:FindFirstChild("SpawnablesClient")
    local con=cl or s
    if con then
        for _,v in ipairs(con:GetChildren()) do
            if v.Name=="clover" and v:IsA("BasePart") then table.insert(out,v) end
        end
    end
    return out
end

local function NearClover()
    local r=Root(); if not r then return nil end
    local best,bd=nil,math.huge
    for _,c in ipairs(GetClovers()) do
        local d=(c.Position-r.Position).Magnitude
        if d<bd then bd=d; best=c end
    end
    return best
end

local function StartClover()
    if cloverLoop then return end
    cloverLoop=task.spawn(function()
        while Config.CloverEnabled and not Destroyed do
            local r=Root(); if not r then task.wait(0.5); continue end
            local cl=NearClover()
            if cl and cl.Parent then
                if Config.CloverTeleport then
                    r.CFrame=CFrame.new(cl.Position+Vector3.new(0,3,0))
                else
                    local c=LocalPlayer.Character
                    local h=c and c:FindFirstChildOfClass("Humanoid")
                    if h then
                        h:MoveTo(cl.Position)
                        local t=tick()
                        repeat task.wait(0.05)
                        until not cl.Parent or (Root() and (Root().Position-cl.Position).Magnitude<4) or tick()-t>5
                    end
                end
                totalTrevos=totalTrevos+1
                if UpdateGUI then UpdateGUI() end
            else task.wait(0.4) end
            task.wait(Config.CloverDelay)
        end
        cloverLoop=nil
    end)
end

local function TogClover()
    Config.CloverEnabled=not Config.CloverEnabled
    if Config.CloverEnabled then StartClover() else cloverLoop=nil end
    if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     CLEANUP
-- ═══════════════════════════════
local function Cleanup()
    Destroyed=true
    Config.AimEnabled=false; Config.EspEnabled=false
    Config.HitboxEnabled=false; Config.CloverEnabled=false
    cloverLoop=nil; Target=nil
    for _,c in ipairs(AllConns) do pcall(function() c:Disconnect() end) end
    AllConns={}
    ClearEsp()
    StopHitbox()
    if FovGui then pcall(function() FovGui:Destroy() end); FovGui=nil; FovRing=nil end
    pcall(function() Camera.CameraType=Enum.CameraType.Custom end)
end

