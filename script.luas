    pg.Size=UDim2.new(1,-24,1,-120); pg.Position=UDim2.new(0,12,0,108)
    pg.BackgroundTransparency=1; pg.BorderSizePixel=0
    pg.ScrollBarThickness=3; pg.ScrollBarImageColor3=Color3.fromRGB(40,40,70)
    pg.CanvasSize=UDim2.new(0,0,0,0); pg.AutomaticCanvasSize=Enum.AutomaticSize.Y
    pg.Visible=(t.n=="AIM")
    TPages[t.n]=pg
    local lay=Instance.new("UIListLayout",pg)
    lay.SortOrder=Enum.SortOrder.LayoutOrder; lay.Padding=UDim.new(0,8)
    local pad=Instance.new("UIPadding",pg); pad.PaddingBottom=UDim.new(0,10)
end

local function SetTab(n)
    ActiveTab=n
    for tn,d in pairs(TBtns) do
        if tn==n then
            TweenService:Create(d.btn,TweenInfo.new(0.15),{BackgroundColor3=d.col}):Play()
            d.btn.TextColor3=Color3.fromRGB(255,255,255)
        else
            TweenService:Create(d.btn,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(22,22,38)}):Play()
            d.btn.TextColor3=Color3.fromRGB(80,80,120)
        end
    end
    for pn,pg in pairs(TPages) do pg.Visible=(pn==n) end
end
for tn,d in pairs(TBtns) do d.btn.MouseButton1Click:Connect(function() SetTab(tn) end) end

-- ── WIDGETS ──────────────────────────────────

local function Card(par,h,ord)
    local c=Instance.new("Frame",par)
    c.Size=UDim2.new(1,0,0,h); c.LayoutOrder=ord or 0
    c.BackgroundColor3=Color3.fromRGB(16,16,28); c.BorderSizePixel=0
    Instance.new("UICorner",c).CornerRadius=UDim.new(0,10)
    Instance.new("UIStroke",c).Color=Color3.fromRGB(28,28,48)
    return c
end

local function SecLbl(par,txt,ord)
    local l=Instance.new("TextLabel",par)
    l.Size=UDim2.new(1,0,0,18); l.LayoutOrder=ord or 0
    l.BackgroundTransparency=1; l.Text="  "..string.upper(txt)
    l.TextColor3=Color3.fromRGB(50,50,85); l.TextSize=10
    l.Font=Enum.Font.GothamBold; l.TextXAlignment=Enum.TextXAlignment.Left
    return l
end

local function BigBtn(par,txt,col,ord)
    local b=Instance.new("TextButton",par)
    b.Size=UDim2.new(1,0,0,46); b.LayoutOrder=ord or 0
    b.BackgroundColor3=col; b.Text=txt
    b.TextColor3=Color3.fromRGB(255,255,255); b.TextSize=13
    b.Font=Enum.Font.GothamBold; b.BorderSizePixel=0
    Instance.new("UICorner",b).CornerRadius=UDim.new(0,10)
    b.MouseEnter:Connect(function() TweenService:Create(b,TweenInfo.new(0.12),{BackgroundTransparency=0.22}):Play() end)
    b.MouseLeave:Connect(function() TweenService:Create(b,TweenInfo.new(0.12),{BackgroundTransparency=0}):Play() end)
    return b
end

local function StatCard(par,ic,icCol,title,sub,ord)
    local c=Card(par,70,ord)
    local ico=Instance.new("TextLabel",c)
    ico.Size=UDim2.new(0,42,0,42); ico.Position=UDim2.new(0,10,0.5,-21)
    ico.BackgroundColor3=icCol; ico.Text=ic; ico.TextSize=22; ico.Font=Enum.Font.GothamBold
    Instance.new("UICorner",ico).CornerRadius=UDim.new(0,10)
    local tl=Instance.new("TextLabel",c)
    tl.Size=UDim2.new(1,-130,0,22); tl.Position=UDim2.new(0,62,0,10)
    tl.BackgroundTransparency=1; tl.Text=title
    tl.TextColor3=Color3.fromRGB(200,200,255); tl.TextSize=15
    tl.Font=Enum.Font.GothamBold; tl.TextXAlignment=Enum.TextXAlignment.Left
    local sl=Instance.new("TextLabel",c)
    sl.Size=UDim2.new(1,-130,0,16); sl.Position=UDim2.new(0,62,0,36)
    sl.BackgroundTransparency=1; sl.Text=sub
    sl.TextColor3=Color3.fromRGB(60,60,100); sl.TextSize=11
    sl.Font=Enum.Font.Gotham; sl.TextXAlignment=Enum.TextXAlignment.Left
    -- Badge
    local bg=Instance.new("Frame",c)
    bg.Size=UDim2.new(0,0,0,22); bg.Position=UDim2.new(1,-10,0.5,-11)
    bg.AnchorPoint=Vector2.new(1,0); bg.BackgroundColor3=Color3.fromRGB(70,25,25)
    bg.BorderSizePixel=0; bg.AutomaticSize=Enum.AutomaticSize.X
    Instance.new("UICorner",bg).CornerRadius=UDim.new(1,0)
    local bgp=Instance.new("UIPadding",bg); bgp.PaddingLeft=UDim.new(0,8); bgp.PaddingRight=UDim.new(0,8)
    local bgl=Instance.new("TextLabel",bg)
    bgl.Size=UDim2.new(0,0,1,0); bgl.AutomaticSize=Enum.AutomaticSize.X
    bgl.BackgroundTransparency=1; bgl.Text="OFF"
    bgl.TextColor3=Color3.fromRGB(255,255,255); bgl.TextSize=10; bgl.Font=Enum.Font.GothamBold
    return c,tl,sl,bg,bgl
end

-- Slider que NÃO move janela
local function MkSlider(par,lbl,mn,mx,def,ac,ord,cb)
    local c=Card(par,64,ord)
    local lt=Instance.new("TextLabel",c)
    lt.Size=UDim2.new(1,-16,0,18); lt.Position=UDim2.new(0,12,0,8)
    lt.BackgroundTransparency=1; lt.Text=lbl..":  "..def
    lt.TextColor3=Color3.fromRGB(170,170,210); lt.TextSize=12
    lt.Font=Enum.Font.GothamBold; lt.TextXAlignment=Enum.TextXAlignment.Left
    local tr=Instance.new("Frame",c)
    tr.Size=UDim2.new(1,-24,0,6); tr.Position=UDim2.new(0,12,0,38)
    tr.BackgroundColor3=Color3.fromRGB(24,24,40); tr.BorderSizePixel=0
    Instance.new("UICorner",tr).CornerRadius=UDim.new(1,0)
    local pct=(def-mn)/(mx-mn)
    local fl=Instance.new("Frame",tr)
    fl.Size=UDim2.new(pct,0,1,0); fl.BackgroundColor3=ac; fl.BorderSizePixel=0
    Instance.new("UICorner",fl).CornerRadius=UDim.new(1,0)
    local kn=Instance.new("Frame",tr)
    kn.Size=UDim2.new(0,18,0,18); kn.AnchorPoint=Vector2.new(0.5,0.5)
    kn.Position=UDim2.new(pct,0,0.5,0); kn.BackgroundColor3=Color3.fromRGB(240,240,255)
    kn.BorderSizePixel=0
    Instance.new("UICorner",kn).CornerRadius=UDim.new(1,0)
    local ks=Instance.new("UIStroke",kn); ks.Color=ac; ks.Thickness=2
    local sd=false
    tr.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
            sd=true; winDrag=false
        end
    end)
    TC(UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sd=false end
    end))
    TC(UserInputService.InputChanged:Connect(function(i)
        if not sd then return end
        if i.UserInputType~=Enum.UserInputType.MouseMovement and i.UserInputType~=Enum.UserInputType.Touch then return end
        local rx=math.clamp((i.Position.X-tr.AbsolutePosition.X)/tr.AbsoluteSize.X,0,1)
        local v=math.floor(mn+rx*(mx-mn))
        fl.Size=UDim2.new(rx,0,1,0); kn.Position=UDim2.new(rx,0,0.5,0)
        lt.Text=lbl..":  "..v; cb(v)
    end))
    return c,lt
end

local function Tog2(par,lbl,def,ord,cb)
    local c=Card(par,46,ord)
    local l=Instance.new("TextLabel",c)
    l.Size=UDim2.new(1,-70,1,0); l.Position=UDim2.new(0,14,0,0)
    l.BackgroundTransparency=1; l.Text=lbl
    l.TextColor3=Color3.fromRGB(165,165,205); l.TextSize=12
    l.Font=Enum.Font.Gotham; l.TextXAlignment=Enum.TextXAlignment.Left
    local tr=Instance.new("TextButton",c)
    tr.Size=UDim2.new(0,48,0,26); tr.Position=UDim2.new(1,-60,0.5,-13)
    tr.BackgroundColor3=def and Color3.fromRGB(0,155,75) or Color3.fromRGB(42,42,62)
    tr.Text=""; tr.BorderSizePixel=0
    Instance.new("UICorner",tr).CornerRadius=UDim.new(1,0)
    local kn=Instance.new("Frame",tr)
    kn.Size=UDim2.new(0,20,0,20); kn.AnchorPoint=Vector2.new(0,0.5)
    kn.Position=def and UDim2.new(1,-23,0.5,0) or UDim2.new(0,3,0.5,0)
    kn.BackgroundColor3=Color3.fromRGB(255,255,255); kn.BorderSizePixel=0
    Instance.new("UICorner",kn).CornerRadius=UDim.new(1,0)
    local st=def
    tr.MouseButton1Click:Connect(function()
        st=not st
        TweenService:Create(tr,TweenInfo.new(0.18),{BackgroundColor3=st and Color3.fromRGB(0,155,75) or Color3.fromRGB(42,42,62)}):Play()
        TweenService:Create(kn,TweenInfo.new(0.18),{Position=st and UDim2.new(1,-23,0.5,0) or UDim2.new(0,3,0.5,0)}):Play()
        cb(st)
    end)
    return c
end

