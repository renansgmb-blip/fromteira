AimBtn.MouseButton1Click:Connect(TogAim)
EspBtn.MouseButton1Click:Connect(TogEsp)
HbBtn.MouseButton1Click:Connect(TogHitbox)
TrBtn.MouseButton1Click:Connect(TogClover)
MA.MouseButton1Click:Connect(TogAim)
ME.MouseButton1Click:Connect(TogEsp)
MH.MouseButton1Click:Connect(TogHitbox)
MG.MouseButton1Click:Connect(TogClover)
MI.MouseButton1Click:Connect(function() SetTab("LISTA") end)

TC(UserInputService.InputBegan:Connect(function(i,gpe)
    if gpe then return end
    if i.KeyCode==Config.ToggleKey       then TogAim()    end
    if i.KeyCode==Config.EspToggleKey    then TogEsp()    end
    if i.KeyCode==Config.HitboxToggleKey then TogHitbox() end
    if i.KeyCode==Config.CloverKey       then TogClover() end
    if i.KeyCode==Config.WhitelistKey    then SetTab("LISTA") end
end))

