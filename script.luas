local TabData = {
    { name = "AIM",   icon = "🎯", color = Color3.fromRGB(0,160,255) },
    { name = "ESP",   icon = "👁",  color = Color3.fromRGB(140,0,255) },
    { name = "TREVO", icon = "🍀", color = Color3.fromRGB(0,180,60)  },
    { name = "LISTA", icon = "👥", color = Color3.fromRGB(255,140,0)  },
}

local TabBtns = {}
local TabPages = {}

for i, t in ipairs(TabData) do
    local btn = Instance.new("TextButton", TabBar)
    btn.Size = UDim2.new(0.25, -4, 1, -8)
    btn.Position = UDim2.new((i-1)*0.25, 2, 0, 4)
    btn.BackgroundColor3 = Color3.fromRGB(28,28,46)
    btn.Text = t.icon.." "..t.name
    btn.TextColor3 = Color3.fromRGB(100,100,140)
    btn.TextSize = 11; btn.Font = Enum.Font.GothamBold
    btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,7)
    TabBtns[t.name] = { btn = btn, color = t.color }

    local page = Instance.new("Frame", Main)
    page.Size = UDim2.new(1, -24, 1, -112); page.Position = UDim2.new(0, 12, 0, 102)
    page.BackgroundTransparency = 1; page.Visible = (t.name == "AIM")
    TabPages[t.name] = page
end

local function SetTab(name)
    ActiveTab = name
    for tname, data in pairs(TabBtns) do
        if tname == name then
            data.btn.BackgroundColor3 = data.color
            data.btn.TextColor3 = Color3.fromRGB(255,255,255)
            TweenService:Create(data.btn, TweenInfo.new(0.15), {BackgroundTransparency=0}):Play()
        else
            data.btn.BackgroundColor3 = Color3.fromRGB(28,28,46)
            data.btn.TextColor3 = Color3.fromRGB(100,100,140)
        end
    end
    for pname, page in pairs(TabPages) do
        page.Visible = (pname == name)
    end
end

for tname, data in pairs(TabBtns) do
    data.btn.MouseButton1Click:Connect(function() SetTab(tname) end)
end

-- ── HELPER DE WIDGETS ────────────────────────────

local function Card(parent, y, h)
    local c = Instance.new("Frame", parent)
    c.Size = UDim2.new(1, 0, 0, h or 56); c.Position = UDim2.new(0, 0, 0, y)
    c.BackgroundColor3 = Color3.fromRGB(20, 20, 34); c.BorderSizePixel = 0
    Instance.new("UICorner", c).CornerRadius = UDim.new(0, 10)
    local cs = Instance.new("UIStroke", c)
    cs.Color = Color3.fromRGB(35,35,58); cs.Thickness = 1
    return c
end

local function BigToggleBtn(parent, y, textOff, textOn, colorOff, colorOn)
    local btn = Instance.new("TextButton", parent)
    btn.Size = UDim2.new(1, 0, 0, 44); btn.Position = UDim2.new(0, 0, 0, y)
    btn.BackgroundColor3 = colorOff; btn.Text = textOff
    btn.TextColor3 = Color3.fromRGB(255,255,255); btn.TextSize = 13
    btn.Font = Enum.Font.GothamBold; btn.BorderSizePixel = 0
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 10)
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundTransparency=0.2}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundTransparency=0}):Play()
    end)
    return btn
end

local function StatusBadge(parent, x, y, text, color)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(0, 0, 0, 22); f.Position = UDim2.new(x, 0, 0, y)
    f.BackgroundColor3 = color; f.BorderSizePixel = 0; f.AutomaticSize = Enum.AutomaticSize.X
    Instance.new("UICorner", f).CornerRadius = UDim.new(1, 0)
    local pad = Instance.new("UIPadding", f)
    pad.PaddingLeft = UDim.new(0,8); pad.PaddingRight = UDim.new(0,8)
    local lbl = Instance.new("TextLabel", f)
    lbl.Size = UDim2.new(0,0,1,0); lbl.AutomaticSize = Enum.AutomaticSize.X
    lbl.BackgroundTransparency = 1; lbl.Text = text
    lbl.TextColor3 = Color3.fromRGB(255,255,255); lbl.TextSize = 10
    lbl.Font = Enum.Font.GothamBold
    return f, lbl
end

local function MkSlider(parent, y, label, min, max, default, onChange)
    local container = Instance.new("Frame", parent)
    container.Size = UDim2.new(1,0,0,54); container.Position = UDim2.new(0,0,0,y)
    container.BackgroundTransparency = 1

    local lbl = Instance.new("TextLabel", container)
    lbl.Size = UDim2.new(1,0,0,18); lbl.BackgroundTransparency = 1
    lbl.Text = label..":  "..default; lbl.TextColor3 = Color3.fromRGB(180,180,220)
    lbl.TextSize = 12; lbl.Font = Enum.Font.GothamBold; lbl.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("Frame", container)
    track.Size = UDim2.new(1,0,0,6); track.Position = UDim2.new(0,0,0,26)
    track.BackgroundColor3 = Color3.fromRGB(30,30,50); track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local fill = Instance.new("Frame", track)
    local pct = (default-min)/(max-min)
    fill.Size = UDim2.new(pct,0,1,0); fill.BackgroundColor3 = Color3.fromRGB(0,160,255)
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0,18,0,18); knob.AnchorPoint = Vector2.new(0.5,0.5)
    knob.Position = UDim2.new(pct,0,0.5,0); knob.BackgroundColor3 = Color3.fromRGB(255,255,255)
    knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)
    local ks = Instance.new("UIStroke", knob); ks.Color = Color3.fromRGB(0,160,255); ks.Thickness = 2

    local dragging = false
    track.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = true end
    end)
    track.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType ~= Enum.UserInputType.MouseMovement and i.UserInputType ~= Enum.UserInputType.Touch then return end
        local relX = math.clamp((i.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + relX*(max-min))
        fill.Size = UDim2.new(relX,0,1,0); knob.Position = UDim2.new(relX,0,0.5,0)
        lbl.Text = label..":  "..val
        onChange(val)
    end)
    return container
end

local function Toggle2(parent, y, labelText, default, onChange)
    local row = Instance.new("Frame", parent)
    row.Size = UDim2.new(1,0,0,32); row.Position = UDim2.new(0,0,0,y)
    row.BackgroundTransparency = 1

    local lbl = Instance.new("TextLabel", row)
    lbl.Size = UDim2.new(1,-56,1,0); lbl.BackgroundTransparency = 1
    lbl.Text = labelText; lbl.TextColor3 = Color3.fromRGB(180,180,220)
    lbl.TextSize = 12; lbl.Font = Enum.Font.Gotham; lbl.TextXAlignment = Enum.TextXAlignment.Left

    local track = Instance.new("TextButton", row)
    track.Size = UDim2.new(0,46,0,24); track.Position = UDim2.new(1,-46,0.5,-12)
    track.BackgroundColor3 = default and Color3.fromRGB(0,160,80) or Color3.fromRGB(50,50,70)
    track.Text = ""; track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1,0)

    local knob = Instance.new("Frame", track)
    knob.Size = UDim2.new(0,18,0,18); knob.AnchorPoint = Vector2.new(0,0.5)
    knob.Position = default and UDim2.new(1,-21,0.5,0) or UDim2.new(0,3,0.5,0)
    knob.BackgroundColor3 = Color3.fromRGB(255,255,255); knob.BorderSizePixel = 0
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1,0)

    local state = default
    track.MouseButton1Click:Connect(function()
        state = not state
        TweenService:Create(track, TweenInfo.new(0.18), {BackgroundColor3 = state and Color3.fromRGB(0,160,80) or Color3.fromRGB(50,50,70)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.18), {Position = state and UDim2.new(1,-21,0.5,0) or UDim2.new(0,3,0.5,0)}):Play()
        onChange(state)
    end)
    return row, track, knob
end

