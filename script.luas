-- ═══════════════════════════════
--     REFRESH WHITELIST UI
-- ═══════════════════════════════

function RefreshWhitelistUI()
    for _, child in ipairs(WLList:GetChildren()) do child:Destroy() end
    if #NearbyList == 0 then
        local el = Instance.new("TextLabel", WLList)
        el.Size = UDim2.new(1,0,0,34); el.BackgroundTransparency = 1
        el.Text = "Nenhum jogador próximo"
        el.TextColor3 = Color3.fromRGB(80,80,120); el.TextSize = 12
        el.Font = Enum.Font.Gotham
        return
    end
    for i, entry in ipairs(NearbyList) do
        local player = entry.player
        local dist   = math.floor(entry.dist)
        local isWL   = Whitelist[player.Name] == true
        local btn = Instance.new("TextButton", WLList)
        btn.Size = UDim2.new(1,0,0,40); btn.Position = UDim2.new(0,0,0,(i-1)*44)
        btn.BackgroundColor3 = isWL and Color3.fromRGB(0,70,25) or Color3.fromRGB(18,18,36)
        btn.BorderSizePixel = 0; btn.Text = ""
        Instance.new("UICorner", btn).CornerRadius = UDim.new(0,7)
        local bS = Instance.new("UIStroke", btn)
        bS.Color = isWL and Color3.fromRGB(0,210,80) or Color3.fromRGB(55,55,110)
        bS.Thickness = 1; bS.Transparency = 0.35
        local nameLbl = Instance.new("TextLabel", btn)
        nameLbl.Size = UDim2.new(1,-52,1,0); nameLbl.Position = UDim2.new(0,10,0,0)
        nameLbl.BackgroundTransparency = 1
        nameLbl.Text = player.Name
        nameLbl.TextColor3 = isWL and Color3.fromRGB(0,255,120) or Color3.fromRGB(220,220,255)
        nameLbl.TextSize = 13; nameLbl.Font = Enum.Font.GothamBold
        nameLbl.TextXAlignment = Enum.TextXAlignment.Left
        local distLbl = Instance.new("TextLabel", btn)
        distLbl.Size = UDim2.new(0,44,1,0); distLbl.Position = UDim2.new(1,-48,0,0)
        distLbl.BackgroundTransparency = 1; distLbl.Text = dist.."m"
        distLbl.TextColor3 = Color3.fromRGB(100,140,255); distLbl.TextSize = 11
        distLbl.Font = Enum.Font.Gotham; distLbl.TextXAlignment = Enum.TextXAlignment.Right
        if isWL then
            local badge = Instance.new("TextLabel", btn)
            badge.Size = UDim2.new(0,22,0,22); badge.Position = UDim2.new(0,10,0.5,-11)
            badge.BackgroundTransparency = 1; badge.Text = "✅"
            badge.TextSize = 14; badge.Font = Enum.Font.Gotham
            nameLbl.Position = UDim2.new(0,30,0,0)
        end
        btn.MouseButton1Click:Connect(function()
            if Whitelist[player.Name] then
                Whitelist[player.Name] = nil
            else
                Whitelist[player.Name] = true
                if Target and Target == player then
                    Target = GetNearestPlayer()
                    if UpdateGUI then UpdateGUI() end
                end
            end
            RefreshWhitelistUI()
        end)
    end
    if WLUpdateLbl and WLUpdateLbl.Parent then
        WLUpdateLbl.Text = "✓ Atualizado"
        task.delay(1, function()
            if WLUpdateLbl and WLUpdateLbl.Parent then
                WLUpdateLbl.Text = "Atualiza a cada "..Config.WhitelistUpdate.."s"
            end
        end)
    end
end

-- ═══════════════════════════════
--        UPDATE GUI
-- ═══════════════════════════════

local aimDotTween = nil
local espDotTween = nil

function UpdateGUI()
    if Config.AimEnabled then
        AimStatusLbl.Text = "AIM:  LIGADO"
        AimStatusLbl.TextColor3 = Color3.fromRGB(0,255,160)
        AimDot.BackgroundColor3 = Color3.fromRGB(0,255,120)
        AimBtn.BackgroundColor3 = Color3.fromRGB(20,180,80)
        AimBtn.Text = "[ T ]  DESATIVAR AIM LOCK"
        MobileBtn.BackgroundColor3 = Color3.fromRGB(20,200,80)
        MobileBtn.Text = "🔒"
        if aimDotTween then aimDotTween:Cancel() end
        aimDotTween = TweenService:Create(AimDot,
            TweenInfo.new(0.45, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
            { BackgroundTransparency = 0.6 })
        aimDotTween:Play()
    else
        AimStatusLbl.Text = "AIM:  DESLIGADO"
        AimStatusLbl.TextColor3 = Color3.fromRGB(180,180,200)
        AimDot.BackgroundColor3 = Color3.fromRGB(255,60,60)
        AimDot.BackgroundTransparency = 0
        AimBtn.BackgroundColor3 = Color3.fromRGB(0,100,200)
        AimBtn.Text = "[ T ]  ATIVAR AIM LOCK"
        MobileBtn.BackgroundColor3 = Color3.fromRGB(0,140,255)
        MobileBtn.Text = "🎯"
        if aimDotTween then aimDotTween:Cancel() end
        TargetLbl.Text = "ALVO:  nenhum"
        TargetLbl.TextColor3 = Color3.fromRGB(100,160,255)
    end
    if Config.EspEnabled then
        EspStatusLbl.Text = "ESP:  LIGADO"
        EspStatusLbl.TextColor3 = Color3.fromRGB(180,100,255)
        EspDot.BackgroundColor3 = Color3.fromRGB(180,80,255)
        EspBtn.BackgroundColor3 = Color3.fromRGB(120,0,220)
        EspBtn.Text = "[ E ]  DESATIVAR ESP"
        MobileEspBtn.BackgroundColor3 = Color3.fromRGB(120,0,220)
        MobileEspBtn.Text = "🚫"
        if espDotTween then espDotTween:Cancel() end
        espDotTween = TweenService:Create(EspDot,
            TweenInfo.new(0.6, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true),
            { BackgroundTransparency = 0.6 })
        espDotTween:Play()
    else
        EspStatusLbl.Text = "ESP:  DESLIGADO"
        EspStatusLbl.TextColor3 = Color3.fromRGB(180,180,200)
        EspDot.BackgroundColor3 = Color3.fromRGB(255,60,60)
        EspDot.BackgroundTransparency = 0
        EspBtn.BackgroundColor3 = Color3.fromRGB(80,0,180)
        EspBtn.Text = "[ E ]  ATIVAR ESP"
        MobileEspBtn.BackgroundColor3 = Color3.fromRGB(80,0,180)
        MobileEspBtn.Text = "👁"
        if espDotTween then espDotTween:Cancel() end
    end
end

-- Heartbeat
RunService.Heartbeat:Connect(function()
    if Config.AimEnabled then
        if Target and IsAlive(Target) then
            TargetLbl.Text = "ALVO:  " .. Target.Name
            TargetLbl.TextColor3 = Color3.fromRGB(0,255,160)
        else
            TargetLbl.Text = "ALVO:  procurando..."
            TargetLbl.TextColor3 = Color3.fromRGB(255,200,0)
        end
    end
    local now = tick()
    if now - lastListUpdate >= Config.WhitelistUpdate then
        lastListUpdate = now
        UpdateNearbyList()
    end
end)

-- ═══════════════════════════════
--     MINIMIZAR / FECHAR
-- ═══════════════════════════════
local minimized = false
MinBtn.MouseButton1Click:Connect(function()
    minimized = not minimized
    if minimized then
        Body.Visible = false
        TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), { Size = UDim2.new(0,255,0,36) }):Play()
        MinBtn.Text = "▢"
    else
        Body.Visible = true
        TweenService:Create(MainFrame, TweenInfo.new(0.2, Enum.EasingStyle.Quad), { Size = UDim2.new(0,255,0,310) }):Play()
        MinBtn.Text = "─"
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
    Cleanup()
    TweenService:Create(MainFrame, TweenInfo.new(0.2), { Size = UDim2.new(0,0,0,0), BackgroundTransparency = 1 }):Play()
    task.wait(0.25)
    ScreenGui:Destroy()
end)

WLCloseBtn.MouseButton1Click:Connect(function() WLFrame.Visible = false end)

local function ToggleWL()
    WLFrame.Visible = not WLFrame.Visible
    if WLFrame.Visible then UpdateNearbyList() end
end

-- ═══════════════════════════════
--     CONTROLES
-- ═══════════════════════════════
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Config.ToggleKey    then ToggleAim() end
    if input.KeyCode == Config.EspToggleKey then ToggleEsp() end
    if input.KeyCode == Config.WhitelistKey then ToggleWL()  end
end)

AimBtn.MouseButton1Click:Connect(ToggleAim)
EspBtn.MouseButton1Click:Connect(ToggleEsp)
WLBtn.MouseButton1Click:Connect(ToggleWL)
MobileBtn.MouseButton1Click:Connect(ToggleAim)
MobileEspBtn.MouseButton1Click:Connect(ToggleEsp)
MobileWLBtn.MouseButton1Click:Connect(ToggleWL)

for _, btn in ipairs({ AimBtn, EspBtn, WLBtn }) do
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), { BackgroundTransparency = 0.25 }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), { BackgroundTransparency = 0 }):Play()
    end)
end

-- ═══════════════════════════════
--     START
-- ═══════════════════════════════
CreateFovCircle()
StartAimLoop()
UpdateGUI()
UpdateNearbyList()
print("✅ AimLock + ESP + FOV + Whitelist!  T=Aim  E=ESP  I=Lista")
