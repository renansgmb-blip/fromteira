-- Slider drag logic
local dragging = false
SliderTrack.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
    end
end)
SliderTrack.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if not dragging then return end
    if input.UserInputType ~= Enum.UserInputType.MouseMovement
    and input.UserInputType ~= Enum.UserInputType.Touch then return end
    local trackPos   = SliderTrack.AbsolutePosition.X
    local trackWidth = SliderTrack.AbsoluteSize.X
    local relX = math.clamp((input.Position.X - trackPos) / trackWidth, 0, 1)
    -- FOV de 10 a 300
    Config.FovSize = math.floor(10 + relX * 290)
    SliderFill.Size = UDim2.new(relX, 0, 1, 0)
    SliderKnob.Position = UDim2.new(relX, 0, 0.5, 0)
    FovLabel.Text = string.format("FOV:  %d", Config.FovSize)
    if FovRing then
        local d = Config.FovSize * 2
        FovRing.Size = UDim2.new(0, d, 0, d)
        FovRing.Position = UDim2.new(0, -Config.FovSize, 0, -Config.FovSize)
    end
end)

