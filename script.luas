-- ╔══════════════════════════════════════╗
-- ║     AIMLOCK + ESP + WHITELIST        ║
-- ║  T = Aim  |  E = ESP  |  I = Lista  ║
-- ╚══════════════════════════════════════╝

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService     = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer
local Camera      = workspace.CurrentCamera

-- ═══════════════════════════════
--          CONFIGURAÇÕES
-- ═══════════════════════════════
local Config = {
    -- AIM
    AimEnabled       = false,
    SmoothFactor     = 1,          -- 1 = instantâneo e preciso
    MaxDistance      = 500,
    AimPart          = "HumanoidRootPart",
    ToggleKey        = Enum.KeyCode.T,

    -- BREAK (só solta alvo, nunca desativa aim)
    BreakSensitivity = 1.5,        -- Graus — bem leve pra desgrudar
    BreakFrames      = 1,

    -- FOV
    FovEnabled       = true,
    FovSize          = 80,         -- Raio em pixels na tela (1-300)
    FovColor         = Color3.fromRGB(255, 255, 255),
    FovTransparency  = 0.5,

    -- ESP
    EspEnabled       = false,
    EspToggleKey     = Enum.KeyCode.E,
    EspBoxColor      = Color3.fromRGB(0, 200, 255),
    EspHealthBar     = true,
    EspDistance      = true,
    EspMaxDist       = 600,

    -- WHITELIST / LISTA
    WhitelistKey     = Enum.KeyCode.I,
    WhitelistCount   = 4,
    WhitelistUpdate  = 1.5,
}

-- ═══════════════════════════════
--           VARIÁVEIS
-- ═══════════════════════════════
local Target         = nil
local AimConnection  = nil
local EspObjects     = {}
local FovCircle      = nil
local Whitelist      = {}
local NearbyList     = {}
local lastCamCF      = Camera.CFrame
local breakCounter   = 0
local lastListUpdate = 0

-- ═══════════════════════════════
--     UTILITÁRIOS
-- ═══════════════════════════════

local function GetMyRoot()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function IsAlive(player)
    if not player then return false end
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    return hum and hum.Health > 0
end

local function GetDistTo(player)
    local myRoot = GetMyRoot()
    if not myRoot then return math.huge end
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return math.huge end
    return (root.Position - myRoot.Position).Magnitude
end

local function IsInFov(player)
    if not Config.FovEnabled then return true end
    local char = player.Character
    if not char then return false end
    local root = char:FindFirstChild(Config.AimPart) or char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
    if not onScreen then return false end
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    local dist = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
    return dist <= Config.FovSize
end

-- ═══════════════════════════════
--     FOV CIRCLE
-- ═══════════════════════════════

local FovGui = nil
local FovRing = nil

local function CreateFovCircle()
    -- Remove anterior
    if FovGui then FovGui:Destroy() end

    -- Cria GUI no CoreGui/PlayerGui
    FovGui = Instance.new("ScreenGui")
    FovGui.Name = "FovCircleGui"
    FovGui.ResetOnSpawn = false
    FovGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    FovGui.DisplayOrder = 998
    pcall(function() FovGui.Parent = game:GetService("CoreGui") end)
    if not FovGui.Parent then FovGui.Parent = LocalPlayer:WaitForChild("PlayerGui") end

    -- Frame central (âncora no centro da tela)
    local container = Instance.new("Frame", FovGui)
    container.Size = UDim2.new(0, 0, 0, 0)
    container.Position = UDim2.new(0.5, 0, 0.5, 0)
    container.BackgroundTransparency = 1
    container.BorderSizePixel = 0

    -- Anel do FOV (UIStroke num frame circular)
    FovRing = Instance.new("Frame", container)
    local d = Config.FovSize * 2
    FovRing.Size = UDim2.new(0, d, 0, d)
    FovRing.Position = UDim2.new(0, -Config.FovSize, 0, -Config.FovSize)
    FovRing.BackgroundTransparency = 1
    FovRing.BorderSizePixel = 0
    Instance.new("UICorner", FovRing).CornerRadius = UDim.new(1, 0)
    local ring = Instance.new("UIStroke", FovRing)
    ring.Color = Color3.fromRGB(255, 255, 255)
    ring.Thickness = 1.5
    ring.Transparency = 0.4

    FovCircle = FovRing  -- compatibilidade
end

local function UpdateFovCircle()
    if not FovRing or not FovRing.Parent then CreateFovCircle() end
    local visible = Config.AimEnabled and Config.FovEnabled
    FovGui.Enabled = visible
    -- Atualiza tamanho se mudou
    local d = Config.FovSize * 2
    FovRing.Size = UDim2.new(0, d, 0, d)
    FovRing.Position = UDim2.new(0, -Config.FovSize, 0, -Config.FovSize)
end



-- ═══════════════════════════════
--     NEARBY LIST
-- ═══════════════════════════════

local function UpdateNearbyList()
    local candidates = {}
    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then continue end
        local dist = GetDistTo(player)
        if dist <= Config.MaxDistance then
            table.insert(candidates, { player = player, dist = dist })
        end
    end
    table.sort(candidates, function(a, b) return a.dist < b.dist end)
    NearbyList = {}
    for i = 1, math.min(Config.WhitelistCount, #candidates) do
        table.insert(NearbyList, candidates[i])
    end
    if RefreshWhitelistUI then RefreshWhitelistUI() end
end

-- ═══════════════════════════════
--     AIM
-- ═══════════════════════════════

local function GetNearestPlayer()
    local nearest     = nil
    local nearestDist = math.huge
    local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)

    for _, player in ipairs(Players:GetPlayers()) do
        if player == LocalPlayer then continue end
        if Whitelist[player.Name] then continue end
        local char = player.Character
        if not char then continue end
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local rootPart = char:FindFirstChild(Config.AimPart) or char:FindFirstChild("HumanoidRootPart")
        if not humanoid or humanoid.Health <= 0 or not rootPart then continue end
        local myRoot = GetMyRoot()
        if not myRoot then continue end
        if (rootPart.Position - myRoot.Position).Magnitude > Config.MaxDistance then continue end
        -- Só considera quem está dentro do FOV
        if not IsInFov(player) then continue end
        local screenPos, onScreen = Camera:WorldToViewportPoint(rootPart.Position)
        if not onScreen then continue end
        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if screenDist < nearestDist then
            nearestDist = screenDist
            nearest = player
        end
    end
    return nearest
end

local function StartAimLoop()
    if AimConnection then AimConnection:Disconnect() end
    lastCamCF    = Camera.CFrame
    breakCounter = 0

    AimConnection = RunService.RenderStepped:Connect(function()
        UpdateFovCircle()
        if not Config.AimEnabled then return end

        -- BREAK: só solta o alvo, NUNCA desativa o aim
        local currentCF  = Camera.CFrame
        local dot        = math.clamp(currentCF.LookVector:Dot(lastCamCF.LookVector), -1, 1)
        local angleDelta = math.deg(math.acos(dot))
        lastCamCF = currentCF

        if angleDelta > Config.BreakSensitivity then
            breakCounter = breakCounter + 1
        else
            breakCounter = math.max(0, breakCounter - 1)
        end

        if breakCounter >= Config.BreakFrames then
            Target       = nil
            breakCounter = 0
            lastCamCF    = Camera.CFrame
        end

        -- Troca alvo se morreu, saiu do FOV ou foi whitelistado
        if not IsAlive(Target) or (Target and Whitelist[Target.Name]) or (Target and not IsInFov(Target)) then
            Target = GetNearestPlayer()
            if UpdateGUI then UpdateGUI() end
            if not Target then return end
        end

        local char     = Target.Character
        local rootPart = char and (char:FindFirstChild(Config.AimPart) or char:FindFirstChild("HumanoidRootPart"))
        if not rootPart then return end

        -- SmoothFactor = 1: lock instantâneo e preciso
        local camPos    = Camera.CFrame.Position
        local direction = (rootPart.Position - camPos).Unit
        local newCF     = CFrame.new(camPos, camPos + direction)
        Camera.CFrame   = Camera.CFrame:Lerp(newCF, Config.SmoothFactor)
    end)
end

local function ToggleAim()
    Config.AimEnabled = not Config.AimEnabled
    if Config.AimEnabled then
        Target       = GetNearestPlayer()
        lastCamCF    = Camera.CFrame
        breakCounter = 0
    else
        Target = nil
    end
    UpdateFovCircle()
    if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     ESP
-- ═══════════════════════════════

local function CreateEspForPlayer(player)
    local obj = {}
    local hl = Instance.new("SelectionBox")
    hl.LineThickness = 0.04
    hl.Color3 = Config.EspBoxColor
    hl.SurfaceTransparency = 1
    hl.SurfaceColor3 = Config.EspBoxColor

    local bb = Instance.new("BillboardGui")
    bb.Size = UDim2.new(0,110,0,50)
    bb.StudsOffset = Vector3.new(0,3,0)
    bb.AlwaysOnTop = true
    bb.ResetOnSpawn = false

    local nameLabel = Instance.new("TextLabel", bb)
    nameLabel.Size = UDim2.new(1,0,0.44,0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.TextColor3 = Color3.fromRGB(255,255,255)
    nameLabel.TextStrokeTransparency = 0.5
    nameLabel.TextStrokeColor3 = Color3.new(0,0,0)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 13
    nameLabel.Text = player.Name

    local infoLabel = Instance.new("TextLabel", bb)
    infoLabel.Size = UDim2.new(1,0,0.36,0)
    infoLabel.Position = UDim2.new(0,0,0.44,0)
    infoLabel.BackgroundTransparency = 1
    infoLabel.TextColor3 = Color3.fromRGB(0,255,160)
    infoLabel.TextStrokeTransparency = 0.5
    infoLabel.TextStrokeColor3 = Color3.new(0,0,0)
    infoLabel.Font = Enum.Font.Gotham
    infoLabel.TextSize = 11
    infoLabel.Text = ""

    obj.hl = hl; obj.bb = bb; obj.infoLabel = infoLabel

    local function attach()
        local char = player.Character
        if not char then return end
        hl.Adornee = char; hl.Parent = workspace
        bb.Adornee = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChildOfClass("BasePart")
        bb.Parent = char
    end
    attach()
    player.CharacterAdded:Connect(attach)

    obj.conn = RunService.Heartbeat:Connect(function()
        local char = player.Character
        if not char then return end
        local hum  = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        local myRoot = GetMyRoot()
        if not hum or not root or not myRoot then return end
        local dist = math.floor((root.Position - myRoot.Position).Magnitude)
        if dist > Config.EspMaxDist then
            hl.Parent = nil; bb.Parent = nil; return
        else
            if hl.Parent ~= workspace then hl.Parent = workspace end
            if bb.Parent ~= char then bb.Parent = char end
        end
        local hp = hum.Health / hum.MaxHealth
        if Target and Target == player then
            hl.Color3 = Color3.fromRGB(255,50,50)
        elseif Whitelist[player.Name] then
            hl.Color3 = Color3.fromRGB(0,255,100)
        elseif hp < 0.35 then
            hl.Color3 = Color3.fromRGB(255,100,0)
        else
            hl.Color3 = Config.EspBoxColor
        end
        local info = ""
        if Config.EspHealthBar then info = info .. string.format("♥%d%%", math.floor(hp*100)) end
        if Config.EspDistance   then info = info .. string.format("  %dm", dist) end
        if Whitelist[player.Name] then info = info .. "  ✅" end
        infoLabel.Text = info
    end)
    return obj
end

local function ClearEsp()
    for _, obj in pairs(EspObjects) do
        if obj.hl   then pcall(function() obj.hl:Destroy()     end) end
        if obj.bb   then pcall(function() obj.bb:Destroy()     end) end
        if obj.conn then pcall(function() obj.conn:Disconnect() end) end
    end
    EspObjects = {}
end

local function ToggleEsp()
    Config.EspEnabled = not Config.EspEnabled
    if Config.EspEnabled then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer then EspObjects[p] = CreateEspForPlayer(p) end
        end
        Players.PlayerAdded:Connect(function(p)
            if Config.EspEnabled then EspObjects[p] = CreateEspForPlayer(p) end
        end)
        Players.PlayerRemoving:Connect(function(p)
            if EspObjects[p] then
                local o = EspObjects[p]
                if o.hl   then pcall(function() o.hl:Destroy()     end) end
                if o.bb   then pcall(function() o.bb:Destroy()     end) end
                if o.conn then pcall(function() o.conn:Disconnect() end) end
                EspObjects[p] = nil
            end
        end)
    else
        ClearEsp()
    end
    if UpdateGUI then UpdateGUI() end
end

-- ═══════════════════════════════
--     CLEANUP (fechar script)
-- ═══════════════════════════════

local function Cleanup()
    -- Desativa tudo
    Config.AimEnabled = false
    Config.EspEnabled = false

    -- Para loop de aim
    if AimConnection then AimConnection:Disconnect() end

    -- Remove ESP
    ClearEsp()

    -- Remove FOV circle
    if FovGui then
        pcall(function() FovGui:Destroy() end)
        FovGui = nil; FovRing = nil; FovCircle = nil
    end

    -- Restaura câmera
    pcall(function()
        Camera.CameraType = Enum.CameraType.Custom
    end)

    print("🧹 AimLock removido com sucesso.")
end

